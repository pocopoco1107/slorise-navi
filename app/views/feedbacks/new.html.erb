<% content_for(:title) { "ご意見・ご要望 - ヨミスロ" } %>

<section class="mt-4 max-w-lg mx-auto">
  <h1 class="text-xl font-bold text-foreground mb-4">ご意見・ご要望</h1>

  <div class="bg-card border border-border rounded-lg p-5">
    <p class="text-sm text-muted-foreground mb-4">
      機能の要望、不具合の報告、店舗の追加リクエストなど、お気軽にお寄せください。
    </p>

    <%= form_with model: @feedback, url: feedbacks_path, class: "space-y-4" do |f| %>
      <% if @feedback.errors.any? %>
        <div class="rounded-lg border border-destructive/20 bg-destructive/5 p-3 text-sm text-destructive">
          <% @feedback.errors.full_messages.each do |msg| %>
            <p><%= msg %></p>
          <% end %>
        </div>
      <% end %>

      <div>
        <label class="block text-sm font-medium text-foreground mb-1">カテゴリ <span class="text-destructive">*</span></label>
        <%= f.select :category,
            Feedback::CATEGORY_LABELS.map { |k, v| [v, k] },
            {},
            class: "w-full border border-input bg-background text-foreground rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-ring focus:border-transparent" %>
      </div>

      <div>
        <label class="block text-sm font-medium text-foreground mb-1">内容 <span class="text-destructive">*</span></label>
        <%= f.text_area :body,
            rows: 5,
            placeholder: "詳しくお聞かせください（1000文字以内）",
            class: "w-full border border-input bg-background text-foreground rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-ring focus:border-transparent resize-y placeholder:text-muted-foreground" %>
      </div>

      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="block text-sm font-medium text-foreground mb-1">お名前（任意）</label>
          <%= f.text_field :name,
              placeholder: "匿名OK",
              class: "w-full border border-input bg-background text-foreground rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-ring focus:border-transparent placeholder:text-muted-foreground" %>
        </div>
        <div>
          <label class="block text-sm font-medium text-foreground mb-1">メール（任意）</label>
          <%= f.email_field :email,
              placeholder: "返信希望の場合",
              class: "w-full border border-input bg-background text-foreground rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-ring focus:border-transparent placeholder:text-muted-foreground" %>
        </div>
      </div>

      <div>
        <%= f.submit "送信する",
            class: "w-full bg-primary text-primary-foreground rounded-md px-4 py-2.5 text-sm font-medium hover:bg-primary/90 transition-colors cursor-pointer min-h-[44px]" %>
      </div>
    <% end %>
  </div>
</section>
