<% content_for(:title) { "スロリセnavi - パチスロリセット・設定判別の投票サイト" } %>

<!-- Hero Section -->
<section class="bg-gradient-to-br from-blue-800 via-blue-900 to-indigo-900 dark:from-gray-800 dark:via-gray-900 dark:to-gray-950 -mx-4 px-4 py-10 sm:py-14 -mt-4 mb-8 rounded-b-2xl">
  <div class="max-w-3xl mx-auto text-center">
    <div class="w-24 h-24 sm:w-28 sm:h-28 mx-auto mb-4">
      <%= image_tag "slot_machine.svg", alt: "スロットマシン", class: "w-full h-full drop-shadow-lg" %>
    </div>
    <h1 class="text-2xl sm:text-3xl font-bold text-white mb-3">
      パチスロの設定情報、<br class="sm:hidden">みんなで集めよう
    </h1>
    <p class="text-blue-200 dark:text-gray-300 text-sm sm:text-base mb-8">
      店舗×機種×日付でリセット・設定予想をワンタップ投票。集合知でホールの傾向を可視化。
    </p>

    <!-- Stats Counters -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 max-w-lg mx-auto">
      <div class="bg-white/10 backdrop-blur rounded-lg px-3 py-3">
        <p class="text-2xl sm:text-3xl font-bold text-white"><%= @today_votes_count %></p>
        <p class="text-blue-300 dark:text-gray-400 text-xs mt-0.5">今日の投票</p>
      </div>
      <div class="bg-white/10 backdrop-blur rounded-lg px-3 py-3">
        <p class="text-2xl sm:text-3xl font-bold text-white"><%= @total_votes_count %></p>
        <p class="text-blue-300 dark:text-gray-400 text-xs mt-0.5">累計投票</p>
      </div>
      <div class="bg-white/10 backdrop-blur rounded-lg px-3 py-3">
        <p class="text-2xl sm:text-3xl font-bold text-white"><%= @shops_count %></p>
        <p class="text-blue-300 dark:text-gray-400 text-xs mt-0.5">登録店舗</p>
      </div>
      <div class="bg-white/10 backdrop-blur rounded-lg px-3 py-3">
        <p class="text-2xl sm:text-3xl font-bold text-white"><%= @machines_count %></p>
        <p class="text-blue-300 dark:text-gray-400 text-xs mt-0.5">主要機種</p>
      </div>
    </div>
  </div>
</section>

<!-- Search -->
<section class="mb-8">
  <%= form_tag root_path, method: :get, data: { turbo_frame: "search_results" }, class: "relative" do %>
    <input type="text" name="q" value="<%= params[:q] %>"
           placeholder="店舗名で検索..."
           class="w-full border border-gray-300 dark:border-gray-600 dark:bg-gray-800 dark:text-gray-100 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent shadow-sm dark:shadow-none dark:placeholder-gray-400"
           autocomplete="off">
    <button type="submit" class="absolute right-2 top-1/2 -translate-y-1/2 bg-blue-700 dark:bg-blue-600 text-white px-4 py-2 rounded-md text-sm hover:bg-blue-600 dark:hover:bg-blue-500 active:scale-95 transition-all duration-150">
      検索
    </button>
  <% end %>

  <turbo-frame id="search_results">
    <% if params[:q].present? && @search_results %>
      <div class="mt-3 bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-4">
        <h2 class="text-sm font-semibold text-gray-600 dark:text-gray-300 mb-3">「<%= params[:q] %>」の検索結果 (<%= @search_results.size %>件)</h2>
        <% if @search_results.any? %>
          <ul class="divide-y divide-gray-100 dark:divide-gray-700">
            <% @search_results.each do |shop| %>
              <li class="py-2">
                <%= link_to shop_path(shop.slug), class: "flex justify-between items-center hover:bg-gray-50 dark:hover:bg-gray-700 -mx-2 px-2 py-2.5 rounded transition-colors duration-150 min-h-[44px]", data: { turbo_frame: "_top" } do %>
                  <span class="font-medium text-sm"><%= shop.name %></span>
                  <span class="text-xs text-gray-500"><%= shop.prefecture.name %></span>
                <% end %>
              </li>
            <% end %>
          </ul>
        <% else %>
          <div class="py-4 flex flex-col items-center">
            <div class="w-16 h-16 mb-2">
              <%= image_tag "empty_search.svg", alt: "見つかりません", class: "w-full h-full opacity-60" %>
            </div>
            <p class="text-sm text-gray-500 dark:text-gray-400">該当する店舗が見つかりませんでした。</p>
          </div>
        <% end %>
      </div>
    <% end %>
  </turbo-frame>
</section>

<!-- Favorite Shops -->
<section class="mb-8" data-controller="favorites-list">
  <div data-favorites-list-target="container" class="hidden bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-4 shadow-sm">
    <h2 class="text-sm font-bold text-gray-800 dark:text-gray-100 mb-2 border-l-4 border-yellow-500 pl-2">お気に入り店舗</h2>
    <ul class="divide-y divide-gray-100 dark:divide-gray-700" data-favorites-list></ul>
  </div>
</section>

<!-- How to Use (3 steps) -->
<section class="mb-8">
  <h2 class="text-lg font-bold text-gray-800 dark:text-gray-100 mb-4">使い方</h2>
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
    <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-4 text-center shadow-sm">
      <div class="w-10 h-10 bg-blue-100 dark:bg-blue-900/50 text-blue-700 dark:text-blue-400 rounded-full flex items-center justify-center mx-auto mb-2 text-lg font-bold">1</div>
      <h3 class="font-semibold text-sm mb-1">店舗を選ぶ</h3>
      <p class="text-xs text-gray-500 dark:text-gray-400">都道府県や検索から<br>行きつけのホールを探す</p>
    </div>
    <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-4 text-center shadow-sm">
      <div class="w-10 h-10 bg-amber-100 dark:bg-amber-900/50 text-amber-700 dark:text-amber-400 rounded-full flex items-center justify-center mx-auto mb-2 text-lg font-bold">2</div>
      <h3 class="font-semibold text-sm mb-1">ワンタップ投票</h3>
      <p class="text-xs text-gray-500 dark:text-gray-400">リセット判別・設定予想を<br>ボタンひとつで投票</p>
    </div>
    <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-4 text-center shadow-sm">
      <div class="w-10 h-10 bg-green-100 dark:bg-green-900/50 text-green-700 dark:text-green-400 rounded-full flex items-center justify-center mx-auto mb-2 text-lg font-bold">3</div>
      <h3 class="font-semibold text-sm mb-1">みんなの結果を見る</h3>
      <p class="text-xs text-gray-500 dark:text-gray-400">集合知でリセット率・<br>設定平均をチェック</p>
    </div>
  </div>
</section>

<!-- Weekly Trend (mini chart) -->
<% if @trend_data&.any? { |d| d[:votes] > 0 } %>
  <section class="mb-8">
    <%= render "shared/trend_chart",
        title: "過去7日間の全国投票推移",
        days_data: @trend_data,
        show_reset: false,
        show_setting: false,
        compact: true %>
  </section>
<% end %>

<!-- AI おすすめ店舗 -->
<% if @recommendations.present? %>
  <section class="mb-8">
    <div class="bg-gradient-to-r from-purple-50 to-pink-50 dark:from-gray-800 dark:to-gray-800 border border-purple-200 dark:border-gray-700 rounded-xl p-4 shadow-sm">
      <h2 class="text-sm font-bold text-gray-800 dark:text-gray-100 mb-3 border-l-4 border-purple-500 pl-2 flex items-center gap-1.5">
        <svg class="w-4 h-4 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
        </svg>
        今日のおすすめ店舗
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
        <% @recommendations.each_with_index do |rec, i| %>
          <%= link_to shop_path(rec.shop.slug), class: "bg-white dark:bg-gray-800 border border-gray-100 dark:border-gray-700 rounded-lg p-3 hover:shadow-md hover:-translate-y-0.5 active:scale-[0.98] transition-all duration-150 block" do %>
            <div class="flex items-start justify-between gap-2">
              <div class="flex items-center gap-2 min-w-0">
                <span class="shrink-0 w-5 h-5 rounded-full flex items-center justify-center text-[10px] font-bold
                  <%= case i when 0 then 'bg-purple-100 dark:bg-purple-900/50 text-purple-700 dark:text-purple-400' when 1 then 'bg-pink-100 dark:bg-pink-900/50 text-pink-700 dark:text-pink-400' else 'bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-400' end %>">
                  <%= i + 1 %>
                </span>
                <p class="font-bold text-sm text-gray-800 dark:text-gray-100 truncate"><%= rec.shop.name %></p>
              </div>
              <% if rec.shop.prefecture %>
                <span class="shrink-0 text-[10px] text-gray-400"><%= rec.shop.prefecture.name %></span>
              <% end %>
            </div>
            <% if rec.reasons.any? %>
              <div class="flex flex-wrap gap-1 mt-2">
                <% rec.reasons.first(2).each do |reason| %>
                  <%
                    badge_class = case reason[:type]
                    when :high_setting then "bg-red-50 dark:bg-red-900/40 text-red-600 dark:text-red-400"
                    when :reset_rate then "bg-green-50 dark:bg-green-900/40 text-green-600 dark:text-green-400"
                    when :vote_volume then "bg-blue-50 dark:bg-blue-900/40 text-blue-600 dark:text-blue-400"
                    when :review_rating then "bg-amber-50 dark:bg-amber-900/40 text-amber-600 dark:text-amber-400"
                    else "bg-gray-50 dark:bg-gray-700 text-gray-500 dark:text-gray-400"
                    end
                  %>
                  <span class="text-[10px] font-medium px-1.5 py-0.5 rounded-full <%= badge_class %>">
                    <%= reason[:label] %>
                  </span>
                <% end %>
              </div>
            <% end %>
          <% end %>
        <% end %>
      </div>
    </div>
  </section>
<% end %>

<!-- Today's Trending Data -->
<section class="mb-8">
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <!-- Hot Shops -->
    <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-4 shadow-sm">
      <h2 class="text-sm font-bold text-gray-800 dark:text-gray-100 mb-3 border-l-4 border-red-500 pl-2">今日の注目店舗</h2>
      <% if @hot_shops.any? %>
        <ol class="space-y-2">
          <% @hot_shops.each_with_index do |item, i| %>
            <li class="flex items-center gap-2">
              <span class="text-xs font-bold text-gray-400 w-4"><%= i + 1 %></span>
              <%= link_to shop_path(item[:shop].slug), class: "text-sm font-medium text-blue-700 dark:text-blue-400 hover:underline truncate flex-1" do %>
                <%= item[:shop].name %>
              <% end %>
              <span class="text-xs text-gray-500 dark:text-gray-400 shrink-0"><%= item[:votes] %>票</span>
            </li>
          <% end %>
        </ol>
      <% else %>
        <p class="text-xs text-gray-400 py-4 text-center">今日の投票データはまだありません</p>
      <% end %>
    </div>

    <!-- High Reset Rate -->
    <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-4 shadow-sm">
      <h2 class="text-sm font-bold text-gray-800 dark:text-gray-100 mb-3 border-l-4 border-green-500 pl-2">今日リセット率が高い機種</h2>
      <% if @high_reset_machines.any? %>
        <ol class="space-y-2">
          <% @high_reset_machines.each_with_index do |item, i| %>
            <li class="flex items-center gap-2">
              <span class="text-xs font-bold text-gray-400 w-4"><%= i + 1 %></span>
              <div class="flex-1 min-w-0">
                <%= link_to machine_path(item[:machine].slug), class: "text-sm font-medium text-blue-700 dark:text-blue-400 hover:underline truncate block" do %>
                  <%= item[:machine].name %>
                <% end %>
                <span class="text-xs text-gray-400"><%= item[:shop].name %></span>
              </div>
              <span class="text-xs font-semibold text-green-600 dark:text-green-400 shrink-0"><%= item[:rate] %>%</span>
            </li>
          <% end %>
        </ol>
      <% else %>
        <p class="text-xs text-gray-400 py-4 text-center">今日のリセットデータはまだありません</p>
      <% end %>
    </div>
  </div>
</section>

<!-- Weekly Voter Ranking -->
<section class="mb-8">
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-4 shadow-sm">
      <h2 class="text-sm font-bold text-gray-800 dark:text-gray-100 mb-3 border-l-4 border-amber-500 pl-2">週間投票ランキング</h2>
      <% if @weekly_ranking.any? %>
        <ol class="space-y-2">
          <% @weekly_ranking.each do |entry| %>
            <li class="flex items-center gap-2">
              <span class="text-xs font-bold w-4 shrink-0 <%= case entry[:rank] when 1 then 'text-amber-500' when 2 then 'text-gray-400' when 3 then 'text-amber-700' else 'text-gray-400' end %>">
                <%= entry[:rank] %>
              </span>
              <span class="text-sm font-medium text-gray-800 dark:text-gray-200 flex-1 truncate"><%= entry[:label] %></span>
              <span class="text-xs text-gray-500 dark:text-gray-400 shrink-0"><%= entry[:count] %>票</span>
            </li>
          <% end %>
        </ol>
      <% else %>
        <p class="text-xs text-gray-400 py-4 text-center">今週の投票データはまだありません</p>
      <% end %>
    </div>

    <div class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-gray-800 dark:to-gray-800 border border-blue-200 dark:border-gray-700 rounded-xl p-4 shadow-sm flex flex-col items-center justify-center text-center">
      <p class="text-3xl mb-2">🏆</p>
      <h2 class="text-sm font-bold text-gray-800 dark:text-gray-100 mb-1">マイステータスを確認</h2>
      <p class="text-xs text-gray-500 dark:text-gray-400 mb-3">投票回数に応じた実績バッジを獲得しよう</p>
      <%= link_to "ステータスを見る", voter_status_path, class: "inline-block bg-blue-700 dark:bg-blue-600 text-white px-5 py-2 rounded-lg text-sm font-medium hover:bg-blue-600 dark:hover:bg-blue-500 active:scale-95 transition-all duration-150 min-h-[44px]" %>
    </div>
  </div>
</section>

<!-- Prefecture Grid -->
<section class="mb-8">
  <h2 class="text-lg font-bold text-gray-800 dark:text-gray-100 mb-4">都道府県から探す</h2>
  <%
    regions = {
      "北海道・東北" => %w[北海道 青森県 岩手県 宮城県 秋田県 山形県 福島県],
      "関東" => %w[茨城県 栃木県 群馬県 埼玉県 千葉県 東京都 神奈川県],
      "中部" => %w[新潟県 富山県 石川県 福井県 山梨県 長野県 岐阜県 静岡県 愛知県],
      "近畿" => %w[三重県 滋賀県 京都府 大阪府 兵庫県 奈良県 和歌山県],
      "中国" => %w[鳥取県 島根県 岡山県 広島県 山口県],
      "四国" => %w[徳島県 香川県 愛媛県 高知県],
      "九州・沖縄" => %w[福岡県 佐賀県 長崎県 熊本県 大分県 宮崎県 鹿児島県 沖縄県]
    }
    prefectures_by_name = @prefectures.index_by(&:name)
  %>

  <% regions.each_with_index do |(region_name, pref_names), index| %>
    <div class="mb-2" data-controller="accordion">
      <button type="button" data-action="click->accordion#toggle"
              class="w-full flex items-center justify-between text-sm font-semibold text-gray-600 dark:text-gray-300 border-l-4 border-blue-700 dark:border-blue-500 pl-2 py-3 hover:text-gray-800 dark:hover:text-gray-100 active:bg-gray-50 dark:active:bg-gray-800 transition-all duration-150 min-h-[44px]">
        <span><%= region_name %></span>
        <svg data-accordion-target="icon" class="w-4 h-4 text-gray-400 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
        </svg>
      </button>
      <div data-accordion-target="content" class="hidden mt-1.5 mb-2">
        <div class="grid grid-cols-4 sm:grid-cols-5 md:grid-cols-7 gap-1.5">
          <% pref_names.each do |pref_name| %>
            <% pref = prefectures_by_name[pref_name] %>
            <% if pref %>
              <%= link_to prefecture_path(pref.slug),
                  class: "bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-md px-2 py-2.5 text-xs text-center hover:bg-blue-700 hover:text-white hover:border-blue-700 dark:hover:bg-blue-600 dark:hover:border-blue-600 active:scale-95 transition-all duration-150 min-h-[44px] flex flex-col items-center justify-center" do %>
                <span class="block truncate"><%= pref_name %></span>
                <% if pref.respond_to?(:shops_count) && pref.shops_count > 0 %>
                  <span class="block text-[10px] text-gray-400"><%= pref.shops_count %>店</span>
                <% end %>
              <% end %>
            <% else %>
              <span class="bg-gray-100 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-md px-2 py-1.5 text-xs text-center text-gray-400 truncate">
                <%= pref_name %>
              </span>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</section>

<!-- Recent Active Shops -->
<section class="mb-8">
  <h2 class="text-lg font-bold text-gray-800 dark:text-gray-100 mb-4">最近の更新店舗</h2>
  <% if @recent_shops.any? %>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      <% @recent_shops.each do |shop| %>
        <%= link_to shop_path(shop.slug), class: "bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-3 hover:shadow-md hover:-translate-y-0.5 active:scale-[0.98] transition-all duration-150 block" do %>
          <div class="flex items-start justify-between gap-2">
            <p class="font-medium text-sm truncate flex-1"><%= shop.name %></p>
            <% if shop.exchange_rate != "unknown_rate" %>
              <span class="shrink-0 text-[10px] font-bold px-1.5 py-0.5 rounded-full
                <%= case shop.exchange_rate
                    when 'equal_rate' then 'bg-emerald-50 dark:bg-emerald-900/40 text-emerald-700 dark:text-emerald-400'
                    when 'rate_56' then 'bg-amber-50 dark:bg-amber-900/40 text-amber-700 dark:text-amber-400'
                    when 'rate_50' then 'bg-orange-50 dark:bg-orange-900/40 text-orange-700 dark:text-orange-400'
                    when 'non_equal' then 'bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300'
                    end %>">
                <%= shop.exchange_rate_display %>
              </span>
            <% end %>
          </div>
          <p class="text-xs text-gray-500 dark:text-gray-400 mt-1"><%= shop.prefecture.name %></p>
          <div class="flex flex-wrap items-center gap-1 mt-1">
            <% if shop.slot_rates.present? %>
              <% shop.slot_rates.each do |rate| %>
                <span class="bg-blue-50 dark:bg-blue-900/40 text-blue-700 dark:text-blue-400 text-[10px] font-medium px-1.5 py-0.5 rounded-full"><%= rate %></span>
              <% end %>
            <% end %>
            <% if shop.business_hours.present? %>
              <span class="text-[10px] text-gray-400"><%= shop.business_hours %></span>
            <% end %>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="flex flex-col items-center py-4">
      <div class="w-16 h-16 mb-2">
        <%= image_tag "empty_search.svg", alt: "データなし", class: "w-full h-full opacity-50" %>
      </div>
      <p class="text-sm text-gray-500 dark:text-gray-400">まだ店舗データがありません。</p>
    </div>
  <% end %>
</section>
