<% content_for(:title) { "ヨミスロ - みんなの記録でパチスロの設定が見える" } %>

<%# JSON-LD structured data for WebSite %>
<% content_for(:head) do %>
  <script type="application/ld+json">
    <%= raw({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "ヨミスロ",
      "url": root_url,
      "description": "パチスロの設定・リセット情報をみんなで記録して傾向をチェック。ログイン不要、匿名OK。",
      "potentialAction": {
        "@type": "SearchAction",
        "target": "#{root_url}search?q={search_term_string}",
        "query-input": "required name=search_term_string"
      }
    }.to_json) %>
  </script>
<% end %>

<!-- ============================================
     Hero (compact tagline)
     ============================================ -->
<section class="relative pb-2 pt-3 md:pb-6 md:pt-10 noise-texture">
  <div class="flex items-center justify-between gap-4 max-w-6xl mx-auto px-4">
    <p class="text-sm text-foreground font-bold md:text-lg" style="font-family: 'Uzura', sans-serif;">
      <span class="text-primary">みんなの記録</span>で設定が見えてくる
    </p>
    <div class="flex items-center gap-3 text-[10px] text-muted-foreground shrink-0 md:text-xs">
      <span><span class="stat-number text-slot-red"><%= number_with_delimiter(@today_votes_count) %></span> 今日</span>
      <span><span class="stat-number text-slot-blue"><%= number_with_delimiter(@total_votes_count) %></span> 累計</span>
    </div>
  </div>
</section>

<!-- ============================================
     Two-Zone Container
     ============================================ -->
<div data-controller="home-tab" class="max-w-6xl mx-auto px-4 pb-5 md:pb-16">

  <!-- Tab Bar (mobile only) -->
  <div class="flex gap-1 p-1 rounded-lg bg-secondary mb-4 sm:hidden">
    <button data-home-tab-target="tabA" data-action="click->home-tab#switchA"
            class="flex-1 flex items-center justify-center gap-1.5 py-2.5 rounded-md text-sm font-semibold transition-all duration-150 min-h-[44px]">
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
        <path d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      店舗・設定
    </button>
    <button data-home-tab-target="tabB" data-action="click->home-tab#switchB"
            class="flex-1 flex items-center justify-center gap-1.5 py-2.5 rounded-md text-sm font-semibold transition-all duration-150 min-h-[44px]">
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
        <path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      マイデータ
    </button>
  </div>

  <!-- Two-column grid on desktop -->
  <div class="sm:grid sm:grid-cols-5 sm:gap-6">

    <!-- ============================================
         Zone A: 店舗・設定情報
         ============================================ -->
    <div data-home-tab-target="zoneA" class="sm:col-span-3 space-y-4">

      <!-- Favorite Shops (fetch後にデータがあれば表示) -->
      <div data-controller="favorites-list">
        <div data-favorites-list-target="container">
          <h2 class="text-sm font-semibold text-foreground mb-3 flex items-center gap-2">
            <svg class="h-4 w-4 text-slot-yellow" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
            お気に入り店舗
          </h2>
          <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2" data-favorites-list></ul>
        </div>
      </div>

      <!-- Search + Nearby -->
      <div class="flex flex-col gap-2">
        <%# 店舗検索 %>
        <div data-controller="hero-search" data-hero-search-url-value="<%= autocomplete_shops_path %>" data-hero-search-type-value="shop" class="relative w-full">
          <svg class="absolute left-4 top-1/2 h-5 w-5 -translate-y-1/2 text-muted-foreground pointer-events-none z-10" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <input type="search"
                 id="hero_shop_search"
                 placeholder="店舗名で検索"
                 autocomplete="off"
                 aria-label="店舗名で検索"
                 data-hero-search-target="input"
                 data-action="input->hero-search#search focus->hero-search#focus"
                 class="h-11 w-full rounded-lg border border-border bg-card pl-11 pr-4 text-sm text-foreground placeholder:text-muted-foreground focus:border-primary focus:ring-1 focus:ring-primary/20 focus:outline-none md:h-14 md:text-lg md:pl-12 transition-colors">
          <div data-hero-search-target="results"
               class="hidden absolute left-0 right-0 top-full mt-1 bg-card border border-border rounded-lg shadow-lg z-30 max-h-[320px] overflow-y-auto divide-y divide-border"></div>
        </div>

        <%# 機種検索 %>
        <div data-controller="hero-search" data-hero-search-url-value="<%= autocomplete_machines_path %>" data-hero-search-type-value="machine" class="relative w-full">
          <svg class="absolute left-4 top-1/2 h-5 w-5 -translate-y-1/2 text-muted-foreground pointer-events-none z-10" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <rect x="2" y="7" width="20" height="14" rx="2" ry="2" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M16 3l-4 4-4-4" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <input type="search"
                 id="hero_machine_search"
                 placeholder="機種名で検索"
                 autocomplete="off"
                 aria-label="機種名で検索"
                 data-hero-search-target="input"
                 data-action="input->hero-search#search"
                 class="h-11 w-full rounded-lg border border-border bg-card pl-11 pr-4 text-sm text-foreground placeholder:text-muted-foreground focus:border-primary focus:ring-1 focus:ring-primary/20 focus:outline-none md:h-14 md:text-lg md:pl-12 transition-colors">
          <div data-hero-search-target="results"
               class="hidden absolute left-0 right-0 top-full mt-1 bg-card border border-border rounded-lg shadow-lg z-30 max-h-[320px] overflow-y-auto divide-y divide-border"></div>
        </div>

        <%# 現在地から探す %>
        <div data-controller="nearby">
          <button type="button"
                  data-nearby-target="button"
                  data-action="click->nearby#locate"
                  class="inline-flex items-center gap-2 rounded-lg border border-border bg-card px-4 py-2.5 text-sm font-medium text-foreground hover:bg-secondary hover:border-primary/50 active:scale-95 transition-all duration-150 min-h-[44px]">
            <svg class="h-5 w-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span data-nearby-target="buttonText">現在地から探す</span>
            <svg data-nearby-target="spinner" class="hidden h-4 w-4 animate-spin text-primary" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
            </svg>
          </button>
          <p data-nearby-target="error" class="hidden mt-2 text-sm text-destructive"></p>

          <div data-nearby-target="fallback" class="hidden mt-3">
            <div class="flex items-center gap-2">
              <svg class="h-5 w-5 text-muted-foreground shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <select id="nearby_prefecture_select" data-action="change->nearby#goToPrefecture"
                      class="flex-1 h-11 rounded-lg border border-border bg-card px-3 text-sm text-foreground focus:border-primary focus:ring-1 focus:ring-primary/20 focus:outline-none transition-colors">
                <option value="">都道府県を選んで探す</option>
                <% @prefectures.each do |pref| %>
                  <option value="<%= pref.slug %>"><%= pref.name %><%= " (#{pref.shops_count}店)" if pref.respond_to?(:shops_count) && pref.shops_count > 0 %></option>
                <% end %>
              </select>
            </div>
          </div>

          <turbo-frame id="nearby_results"></turbo-frame>
        </div>
      </div>

      <!-- Prefecture Grid -->
      <div id="prefectures">
        <h2 class="text-sm font-semibold text-foreground mb-3">都道府県から探す</h2>

        <%
          regions = {
            "北海道・東北" => %w[北海道 青森県 岩手県 宮城県 秋田県 山形県 福島県],
            "関東" => %w[茨城県 栃木県 群馬県 埼玉県 千葉県 東京都 神奈川県],
            "中部" => %w[新潟県 富山県 石川県 福井県 山梨県 長野県 岐阜県 静岡県 愛知県],
            "近畿" => %w[三重県 滋賀県 京都府 大阪府 兵庫県 奈良県 和歌山県],
            "中国" => %w[鳥取県 島根県 岡山県 広島県 山口県],
            "四国" => %w[徳島県 香川県 愛媛県 高知県],
            "九州・沖縄" => %w[福岡県 佐賀県 長崎県 熊本県 大分県 宮崎県 鹿児島県 沖縄県]
          }
          prefectures_by_name = @prefectures.index_by(&:name)
        %>

        <%
          region_colors = %w[bg-slot-blue bg-slot-yellow bg-slot-green bg-slot-red bg-slot-blue bg-slot-yellow bg-slot-green]
        %>
        <% regions.each_with_index do |(region_name, pref_names), region_idx| %>
          <div class="mb-1" data-controller="accordion">
            <button type="button" data-action="click->accordion#toggle"
                    class="w-full flex items-center justify-between text-sm font-semibold text-muted-foreground py-2.5 hover:text-foreground active:bg-secondary/50 transition-all duration-150 min-h-[44px] rounded-md px-2">
              <div class="flex items-center gap-2">
                <div class="h-4 w-1 rounded-full <%= region_colors[region_idx] %>"></div>
                <span><%= region_name %></span>
              </div>
              <svg data-accordion-target="icon" class="w-4 h-4 text-muted-foreground transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </button>
            <div data-accordion-target="content" class="hidden mt-1 mb-1.5">
              <div class="flex flex-wrap gap-1.5">
                <% pref_names.each do |pref_name| %>
                  <% pref = prefectures_by_name[pref_name] %>
                  <% if pref %>
                    <%= link_to prefecture_path(pref.slug),
                        class: "bg-card rounded-md px-3 py-2 text-xs text-center hover:bg-primary hover:text-primary-foreground active:scale-95 transition-all duration-150 min-h-[40px] inline-flex items-center gap-1 shadow-sm" do %>
                      <span class="text-foreground whitespace-nowrap"><%= pref_name.sub(/[県]$/, '') %></span>
                      <% if pref.respond_to?(:shops_count) && pref.shops_count > 0 %>
                        <span class="text-[10px] text-muted-foreground"><%= pref.shops_count %></span>
                      <% end %>
                    <% end %>
                  <% else %>
                    <span class="bg-muted border border-border rounded-md px-3 py-2 text-xs text-muted-foreground whitespace-nowrap">
                      <%= pref_name.sub(/[県]$/, '') %>
                    </span>
                  <% end %>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>

      <!-- Weekly High Setting Machines -->
      <div class="rounded-lg bg-card border-b border-border/50 p-3">
        <h2 class="text-xs font-semibold text-muted-foreground mb-2 flex items-center gap-1.5">
          <div class="h-1.5 w-1.5 rounded-full bg-slot-red"></div>
          今週の高設定ランキング
        </h2>
        <% if @weekly_high_setting_machines.any? %>
          <ol class="space-y-1.5">
            <% @weekly_high_setting_machines.each_with_index do |item, i| %>
              <li class="flex items-center gap-2">
                <span class="text-[10px] font-bold tabular-nums w-3 shrink-0
                  <%= case i when 0 then 'text-yellow-500' when 1 then 'text-muted-foreground' when 2 then 'text-amber-700' else 'text-muted-foreground' end %>">
                  <%= i + 1 %>
                </span>
                <%= link_to machine_path(item[:machine].slug), class: "text-xs text-primary hover:underline truncate flex-1", data: { turbo_frame: "_top" } do %>
                  <%= item[:machine].name %>
                <% end %>
                <span class="text-[10px] font-medium px-1.5 py-0.5 rounded-full bg-destructive/10 text-destructive shrink-0">
                  <%= item[:pct] %>%
                </span>
                <span class="text-[10px] tabular-nums text-muted-foreground shrink-0"><%= item[:high_count] %>/<%= item[:total_count] %></span>
              </li>
            <% end %>
          </ol>
        <% else %>
          <p class="text-xs text-muted-foreground py-2 text-center">今週はまだデータなし</p>
        <% end %>
      </div>

      <!-- Trending Shops -->
      <% if @recommendations.present? %>
        <div class="rounded-lg bg-card border-b border-border/50 p-3">
          <h2 class="text-xs font-semibold text-muted-foreground mb-2 flex items-center gap-1.5">
            <div class="h-1.5 w-1.5 rounded-full bg-slot-red"></div>
            トレンド店舗
          </h2>
          <ol class="space-y-1.5">
            <% @recommendations.each_with_index do |rec, i| %>
              <li>
                <%= link_to shop_path(rec.shop.slug), class: "group flex items-center gap-2 py-0.5 transition-colors", data: { turbo_frame: "_top" } do %>
                  <span class="shrink-0 w-3 text-[10px] font-bold tabular-nums text-muted-foreground"><%= i + 1 %></span>
                  <span class="text-xs text-foreground truncate flex-1 group-hover:text-primary transition-colors"><%= favorite_mark(rec.shop) %> <%= rec.shop.name %></span>
                  <% if rec.shop.prefecture %>
                    <span class="shrink-0 text-[10px] text-muted-foreground"><%= rec.shop.prefecture.name %></span>
                  <% end %>
                <% end %>
              </li>
            <% end %>
          </ol>
        </div>
      <% end %>

    </div>

    <!-- ============================================
         Zone B: マイデータ
         ============================================ -->
    <div data-home-tab-target="zoneB" class="zone-hidden sm:col-span-2">
      <div class="sm:sticky sm:top-20 space-y-4">

        <!-- User Card -->
        <% if @voter_label %>
          <%= link_to voter_status_path, class: "block rounded-lg bg-card border border-border/50 p-3 hover:border-primary/50 transition-all" do %>
            <div class="flex items-center justify-between">
              <div class="min-w-0">
                <p class="text-sm font-semibold text-foreground truncate"><%= @voter_label %></p>
                <% if @voter_rank_title %>
                  <p class="text-[10px] text-muted-foreground"><%= @voter_rank_title %></p>
                <% end %>
              </div>
              <svg class="w-4 h-4 text-muted-foreground shrink-0 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M9 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <div class="flex items-center gap-3 mt-2">
              <% if @voter_streak > 0 %>
                <span class="inline-flex items-center gap-1 text-[10px] font-medium text-slot-red">
                  🔥 <%= @voter_streak %>日連続
                </span>
              <% end %>
              <span class="inline-flex items-center gap-1 text-[10px] font-medium text-slot-yellow">
                ⚡ <%= @voter_points %>pt
              </span>
            </div>
            <% if @voter_badges.present? %>
              <div class="flex items-center gap-1.5 mt-2">
                <% @voter_badges.each do |badge| %>
                  <span class="text-sm" title="<%= badge[:name] %>"><%= badge[:icon] %></span>
                <% end %>
              </div>
            <% end %>
          <% end %>
        <% else %>
          <%= link_to voter_status_path, class: "block rounded-lg bg-surface-inset p-3 hover:bg-card transition-all" do %>
            <div class="flex items-center justify-between">
              <div class="min-w-0">
                <p class="text-sm font-semibold text-foreground">記録するほど称号が上がる</p>
                <p class="text-[10px] text-muted-foreground">的中率も連続記録も自動カウント</p>
              </div>
              <svg class="w-4 h-4 text-muted-foreground shrink-0 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M9 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
          <% end %>
        <% end %>

        <!-- Play Summary + CTA -->
        <% if @my_play_summary %>
          <div class="rounded-lg bg-card border-l-2 border-l-primary p-4">
            <h2 class="text-sm font-semibold text-foreground mb-2">今月の収支</h2>
            <div class="flex items-center gap-6 mb-3">
              <span class="text-xl font-bold tabular-nums <%= @my_play_summary[:total] >= 0 ? 'text-primary' : 'text-destructive' %>">
                <%= @my_play_summary[:total] >= 0 ? '+' : '' %><%= number_with_delimiter(@my_play_summary[:total]) %>円
              </span>
              <span class="text-xs text-muted-foreground">
                稼働<%= @my_play_summary[:days] %>日 / 勝率<%= @my_play_summary[:win_rate] %>%
              </span>
            </div>
            <%= link_to play_records_path, class: "inline-flex items-center justify-center gap-1.5 bg-primary text-primary-foreground px-4 py-2 rounded-lg text-sm font-medium hover:bg-primary/90 active:scale-95 transition-all duration-150 min-h-[44px] w-full" do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
              </svg>
              収支カレンダー
            <% end %>
          </div>
        <% else %>
          <div class="rounded-lg bg-card border-l-2 border-l-slot-yellow p-4">
            <h2 class="text-sm font-semibold text-foreground mb-1">収支カレンダー</h2>
            <p class="text-xs text-muted-foreground mb-3">打った結果をポチるだけ。月間収支も勝率も勝手にまとまる。</p>
            <%= link_to play_records_path, class: "inline-flex items-center justify-center gap-1.5 bg-primary text-primary-foreground px-4 py-2 rounded-lg text-sm font-medium hover:bg-primary/90 active:scale-95 transition-all duration-150 min-h-[44px] w-full" do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M12 4v16m8-8H4" stroke-linecap="round"/></svg>
              収支を記録する
            <% end %>
          </div>
        <% end %>

        <!-- Points Ranking -->
        <div class="rounded-lg bg-card border-b border-border/50 p-3">
          <h2 class="text-xs font-semibold text-muted-foreground mb-2 flex items-center gap-1.5">
            <div class="h-1.5 w-1.5 rounded-full bg-slot-yellow"></div>
            ポイントランキング
          </h2>
          <% if @points_ranking.any? %>
            <ol class="space-y-1.5">
              <% @points_ranking.each do |entry| %>
                <li class="flex items-center gap-2">
                  <span class="text-[10px] font-bold tabular-nums w-3 shrink-0 <%= case entry[:rank] when 1 then 'text-yellow-500' when 2 then 'text-muted-foreground' when 3 then 'text-amber-700' else 'text-muted-foreground' end %>">
                    <%= entry[:rank] %>
                  </span>
                  <span class="text-xs text-foreground flex-1 truncate"><%= entry[:label] %></span>
                  <span class="text-[10px] tabular-nums text-muted-foreground shrink-0"><%= entry[:points] %>pt</span>
                </li>
              <% end %>
            </ol>
          <% else %>
            <p class="text-xs text-muted-foreground py-2 text-center">まだデータなし</p>
          <% end %>
          <div class="mt-2 text-center">
            <%= link_to "すべて見る →", rankings_path, class: "text-[10px] text-primary hover:underline" %>
          </div>
        </div>

      </div>
    </div>

  </div>
</div>
