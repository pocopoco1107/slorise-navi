<% content_for(:title) { "#{@machine_model.name} - スロリセnavi" } %>

<%# JSON-LD structured data %>
<% content_for(:head) do %>
  <script type="application/ld+json">
    <%= raw({
      "@context": "https://schema.org",
      "@type": "Product",
      "name": @machine_model.name,
      "description": [@machine_model.type_detail, @machine_model.payout_rate_display ? "機械割#{@machine_model.payout_rate_display}" : nil].compact.join(" / ").presence || "パチスロ機種",
      "brand": @machine_model.maker.present? ? { "@type": "Brand", "name": @machine_model.maker } : nil,
      "image": @machine_model.image_url.presence,
      "category": "パチスロ",
      "additionalProperty": [
        @machine_model.generation_label ? { "@type": "PropertyValue", "name": "号機区分", "value": @machine_model.generation_label } : nil,
        @machine_model.payout_rate_display ? { "@type": "PropertyValue", "name": "機械割", "value": @machine_model.payout_rate_display } : nil,
        @machine_model.type_detail.present? ? { "@type": "PropertyValue", "name": "タイプ", "value": @machine_model.type_detail } : nil,
        { "@type": "PropertyValue", "name": "設置店舗数", "value": @installed_shop_count.to_s }
      ].compact
    }.compact.to_json) %>
  </script>
<% end %>

<section class="mt-4">
  <%# === Breadcrumb === %>
  <nav aria-label="breadcrumb" class="mb-4">
    <ol class="flex flex-wrap items-center gap-1.5 text-sm text-muted-foreground">
      <li class="inline-flex items-center gap-1.5">
        <%= link_to "ホーム", root_path, class: "hover:text-foreground transition-colors" %>
      </li>
      <li aria-hidden="true">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </li>
      <li class="inline-flex items-center gap-1.5">
        <span class="text-foreground font-normal"><%= @machine_model.name %></span>
      </li>
    </ol>
  </nav>

  <%# === Machine Info Card === %>
  <div class="bg-card border border-border rounded-lg p-4 mb-6">
    <div class="flex gap-4">
      <%# 機種画像 (あれば) %>
      <% if @machine_model.image_url.present? %>
        <div class="shrink-0">
          <img src="<%= @machine_model.image_url %>"
               alt="<%= @machine_model.name %>"
               loading="lazy"
               class="w-24 h-24 sm:w-32 sm:h-32 object-contain rounded-lg bg-secondary"
               onerror="this.parentElement.style.display='none'">
        </div>
      <% end %>

      <div class="flex-1 min-w-0">
        <%# 機種名 + バッジ群 %>
        <h1 class="text-xl md:text-2xl font-bold text-foreground leading-tight"><%= @machine_model.name %></h1>
        <div class="flex flex-wrap items-center gap-1.5 mt-1.5">
          <span class="text-[11px] font-bold px-2 py-0.5 rounded-md <%= @machine_model.display_type_badge_class %>">
            <%= @machine_model.display_type_label %>
          </span>
          <% if @machine_model.generation_label %>
            <span class="text-[11px] font-bold px-2 py-0.5 rounded-md <%= @machine_model.generation_badge_class %>">
              <%= @machine_model.generation_label %>
            </span>
          <% end %>
          <% if @machine_model.smart_slot? %>
            <span class="text-[11px] font-bold px-2 py-0.5 rounded-md bg-confirmed/10 text-confirmed border border-confirmed/20">
              スマスロ
            </span>
          <% elsif @machine_model.display_type != :smart_slot %>
            <span class="text-[11px] font-bold px-2 py-0.5 rounded-md bg-secondary text-secondary-foreground">
              メダル機
            </span>
          <% end %>
        </div>

        <%# スペック情報 %>
        <div class="mt-2.5 space-y-1">
          <% if @machine_model.payout_rate_display %>
            <div class="flex items-center gap-1.5 text-sm">
              <span class="text-muted-foreground">機械割:</span>
              <span class="text-2xl font-bold text-foreground tabular-nums"><%= @machine_model.payout_rate_display %></span>
            </div>
          <% end %>
          <% if @machine_model.type_detail.present? %>
            <div class="flex items-start gap-1.5 text-sm">
              <span class="text-muted-foreground shrink-0">タイプ:</span>
              <span class="font-medium text-foreground"><%= @machine_model.type_detail %></span>
            </div>
          <% end %>
        </div>

        <%# メタ情報行 %>
        <div class="mt-2 flex flex-wrap gap-x-4 gap-y-1 text-xs text-muted-foreground">
          <% if @machine_model.maker.present? %>
            <span>メーカー: <span class="font-medium text-foreground"><%= @machine_model.maker %></span></span>
          <% end %>
          <% if @machine_model.effective_introduced_on.present? %>
            <span>導入日: <span class="font-medium text-foreground"><%= @machine_model.effective_introduced_on.strftime("%Y年%-m月%-d日") %></span></span>
          <% end %>
          <span>設置店舗: <span class="font-medium text-foreground"><%= @installed_shop_count %>店</span></span>
        </div>
      </div>
    </div>

    <%# 検定番号 (折りたたみ) %>
    <% if @machine_model.certification_number.present? %>
      <details class="mt-3 border-t border-border pt-2">
        <summary class="text-[11px] text-muted-foreground cursor-pointer hover:text-foreground select-none">
          検定番号を表示
        </summary>
        <p class="text-xs text-muted-foreground mt-1 font-mono"><%= @machine_model.certification_number %></p>
      </details>
    <% end %>
  </div>

  <%# === All-time Stats === %>
  <% if @all_time_votes && @all_time_votes > 0 %>
    <div class="bg-card border border-border rounded-lg p-4 mb-6">
      <h2 class="text-sm font-bold text-foreground mb-3 flex items-center gap-2">
        <span class="w-1 h-4 bg-chart-1 rounded-full"></span>
        全期間の統計
      </h2>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        <div class="bg-secondary rounded-lg p-3 text-center">
          <p class="text-xl font-bold text-foreground tabular-nums"><%= @all_time_votes %></p>
          <p class="text-[10px] text-muted-foreground">総投票数</p>
        </div>
        <div class="bg-secondary rounded-lg p-3 text-center">
          <p class="text-xl font-bold text-foreground tabular-nums"><%= @total_vote_days %></p>
          <p class="text-[10px] text-muted-foreground">投票日数</p>
        </div>
        <% if @all_time_reset_rate %>
          <div class="bg-secondary rounded-lg p-3 text-center">
            <p class="text-xl font-bold tabular-nums <%= @all_time_reset_rate >= 50 ? 'text-vote-yes' : 'text-vote-no' %>"><%= @all_time_reset_rate %>%</p>
            <p class="text-[10px] text-muted-foreground">リセット率</p>
          </div>
        <% end %>
        <% if @all_time_setting_avg %>
          <div class="bg-secondary rounded-lg p-3 text-center">
            <%
              avg_color = case @all_time_setting_avg
                          when 0..2 then 'text-setting-1'
                          when 2..4 then 'text-setting-4'
                          else 'text-setting-6'
                          end
            %>
            <p class="text-xl font-bold tabular-nums <%= avg_color %>"><%= @all_time_setting_avg %></p>
            <p class="text-[10px] text-muted-foreground">平均設定</p>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# === Trend Chart === %>
  <% if @trend_data&.any? { |d| d[:votes] > 0 } %>
    <%= render "shared/trend_chart",
        title: "過去7日間の全国投票トレンド",
        days_data: @trend_data %>
  <% end %>

  <%# === Trophy Rules === %>
  <% if @machine_model.trophy_rules.present? %>
    <div class="bg-card border border-border rounded-lg p-4 mb-6">
      <h2 class="text-sm font-bold text-foreground mb-2 flex items-center gap-2">
        <span class="w-1 h-4 bg-confirmed rounded-full"></span>
        確定演出・設定示唆
      </h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-2">
        <% @machine_model.trophy_rules.each do |演出, 設定| %>
          <div class="bg-confirmed/10 border border-confirmed/20 rounded-lg px-3 py-2 text-center">
            <p class="text-xs text-muted-foreground"><%= 演出 %></p>
            <p class="text-sm font-bold text-confirmed"><%= 設定 %></p>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# === SNS Reports === %>
  <% if @sns_reports.any? %>
    <div class="bg-card border border-border rounded-lg p-4 mb-6">
      <h2 class="text-sm font-bold text-foreground mb-2 flex items-center gap-2">
        <span class="w-1 h-4 bg-chart-1 rounded-full"></span>
        SNS情報 (自動収集)
      </h2>
      <div class="space-y-2">
        <% @sns_reports.each do |report| %>
          <div class="border border-border rounded-lg p-2.5">
            <div class="flex items-center gap-2 mb-1">
              <% if report.trophy_type.present? %>
                <span class="bg-confirmed/10 text-confirmed text-xs font-medium rounded-md px-2 py-0.5"><%= report.trophy_type %></span>
              <% end %>
              <% if report.suggested_setting.present? %>
                <span class="bg-setting-4/10 text-setting-4 text-xs font-medium rounded-md px-2 py-0.5"><%= report.suggested_setting %></span>
              <% end %>
              <span class="text-xs text-muted-foreground ml-auto"><%= report.reported_on&.strftime("%-m/%-d") %></span>
            </div>
            <p class="text-xs text-muted-foreground line-clamp-2"><%= report.source_title %></p>
          </div>
        <% end %>
      </div>
      <p class="text-[10px] text-muted-foreground mt-2">※ RSS等から自動収集した情報です。正確性は保証しません。</p>
    </div>
  <% end %>

  <%# === Guide Links === %>
  <% if @guide_links.any? %>
    <div class="bg-card border border-border rounded-lg p-4 mb-6">
      <h2 class="text-sm font-bold text-foreground mb-3 flex items-center gap-2">
        <span class="w-1 h-4 bg-primary rounded-full"></span>
        攻略情報
      </h2>
      <div class="space-y-2">
        <% @guide_links.group_by(&:link_type).each do |type, links| %>
          <% links.each do |guide_link| %>
            <a href="<%= guide_link.url %>" target="_blank" rel="noopener noreferrer"
               class="flex items-center gap-2 border border-border rounded-lg px-3 py-2.5 hover:bg-secondary transition-colors block">
              <span class="text-base shrink-0"><%= guide_link.link_type_icon %></span>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-foreground truncate"><%= guide_link.title || guide_link.url %></p>
                <div class="flex items-center gap-2 mt-0.5">
                  <span class="text-[10px] font-bold px-1.5 py-0.5 rounded-md bg-secondary text-secondary-foreground"><%= guide_link.link_type_label %></span>
                  <span class="text-[10px] text-muted-foreground"><%= guide_link.source %></span>
                </div>
              </div>
              <svg class="w-4 h-4 text-muted-foreground shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          <% end %>
        <% end %>
      </div>
      <p class="text-[10px] text-muted-foreground mt-2">※ 外部サイトの情報です。最新情報は各サイトでご確認ください。</p>
    </div>
  <% end %>

  <%# === Today's Votes === %>
  <h2 class="text-lg font-bold text-foreground mb-3">本日の投票状況 (<%= Date.current.strftime("%-m/%-d") %>)</h2>

  <% if @vote_summaries.any? %>
    <div class="space-y-2 mb-6">
      <% @vote_summaries.each do |vs| %>
        <div class="bg-card border border-border rounded-lg p-3">
          <div class="flex items-center justify-between">
            <%= link_to shop_path(vs.shop.slug), class: "font-medium text-sm text-primary hover:underline" do %>
              <%= vs.shop.name %>
            <% end %>
            <span class="text-xs text-muted-foreground tabular-nums"><%= vs.total_votes %>票</span>
          </div>
          <div class="mt-2 flex flex-wrap gap-4 text-xs text-muted-foreground">
            <div>
              リセット:
              <% total_reset = vs.reset_yes_count + vs.reset_no_count %>
              <% if total_reset >= 3 %>
                <span class="font-semibold text-vote-yes"><%= (vs.reset_yes_count.to_f / total_reset * 100).round %>% Yes</span>
                (<%= total_reset %>票)
              <% else %>
                <span class="text-muted-foreground">データ不足</span>
              <% end %>
            </div>
            <div>
              設定:
              <% if vs.setting_avg.present? && vs.total_votes >= 3 %>
                <span class="font-semibold text-foreground">平均<%= vs.setting_avg %></span>
                (<%= vs.total_votes %>票)
              <% else %>
                <span class="text-muted-foreground">データ不足</span>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <div class="mb-6">
      <nav class="flex justify-center">
        <%= paginate @vote_summaries %>
      </nav>
    </div>
  <% else %>
    <div class="bg-card border border-border rounded-lg p-8 text-center mb-6">
      <div class="w-16 h-16 mx-auto mb-2">
        <%= image_tag "empty_search.svg", alt: "投票なし", class: "w-full h-full opacity-50" %>
      </div>
      <p class="text-muted-foreground text-sm">本日の投票データはまだありません。</p>
    </div>
  <% end %>

  <%# === Installed Shops === %>
  <div class="mb-6">
    <h2 class="text-lg font-bold text-foreground mb-3">設置店舗を探す (<%= @installed_shop_count %>店)</h2>

    <!-- Prefecture Filter -->
    <div class="bg-card border border-border rounded-lg p-3 mb-4">
      <div class="flex items-center gap-2 flex-wrap">
        <span class="text-xs text-muted-foreground font-medium shrink-0">都道府県:</span>
        <%= form_tag machine_path(@machine_model.slug), method: :get, class: "flex items-center gap-2 flex-1" do %>
          <select name="prefecture" onchange="this.form.submit()"
                  class="flex-1 min-w-[140px] border border-input bg-background text-foreground rounded-md px-2 py-1.5 text-xs focus:outline-none focus:ring-1 focus:ring-ring">
            <option value="">全国</option>
            <% @available_prefectures.each do |pref| %>
              <option value="<%= pref.slug %>" <%= "selected" if params[:prefecture] == pref.slug %>><%= pref.name %></option>
            <% end %>
          </select>
        <% end %>
      </div>
    </div>

    <% if @installed_shops.any? %>
      <!-- Rate Filter (Client-side) -->
      <div data-controller="machine-shop-filter">
        <%
          all_rates = @installed_shops.flat_map { |s| s.slot_rates || [] }.uniq.sort
        %>
        <% if all_rates.any? %>
          <div class="flex items-center gap-2 flex-wrap mb-3">
            <span class="text-xs text-muted-foreground font-medium shrink-0">レート:</span>
            <% all_rates.each do |rate| %>
              <button type="button"
                      data-machine-shop-filter-target="rateButton"
                      data-action="click->machine-shop-filter#toggleRate"
                      data-rate="<%= rate %>"
                      class="bg-secondary text-secondary-foreground text-[11px] px-3 py-1.5 rounded-md border border-border hover:bg-primary/10 hover:text-primary active:scale-95 transition-all duration-150 cursor-pointer min-h-[32px]">
                <%= rate %>
              </button>
            <% end %>
            <button type="button"
                    data-action="click->machine-shop-filter#clearRates"
                    class="text-[10px] text-muted-foreground hover:text-foreground underline cursor-pointer">
              クリア
            </button>
            <span data-machine-shop-filter-target="count" class="text-[10px] text-muted-foreground ml-auto"></span>
          </div>
        <% end %>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2 mb-4">
          <% @installed_shops.group_by { |s| s.prefecture.name }.each do |pref_name, shops| %>
            <% shops.each do |shop| %>
              <%= link_to shop_path(shop.slug),
                    data: { machine_shop_filter_target: "card", rates: (shop.slot_rates || []).join(",") },
                    class: "bg-card border border-border rounded-lg px-3 py-2.5 hover:bg-secondary hover:-translate-y-0.5 active:scale-[0.98] transition-all duration-150 block min-h-[44px]" do %>
                <div class="flex items-center justify-between gap-2">
                  <span class="text-sm font-medium text-primary truncate"><%= shop.name %></span>
                  <span class="text-[10px] text-muted-foreground shrink-0"><%= pref_name %></span>
                </div>
                <div class="flex flex-wrap items-center gap-1 mt-1.5">
                  <% if shop.slot_rates.present? %>
                    <% shop.slot_rates.each do |rate| %>
                      <span class="bg-primary/10 text-primary text-[10px] px-1.5 py-0.5 rounded-md"><%= rate %></span>
                    <% end %>
                  <% end %>
                  <% if shop.exchange_rate != "unknown_rate" %>
                    <span class="text-[10px] text-muted-foreground"><%= shop.exchange_rate_display %></span>
                  <% end %>
                  <% unit = @unit_counts[shop.id] %>
                  <% if unit %>
                    <span class="text-[10px] text-setting-4"><%= unit %>台</span>
                  <% end %>
                  <% if shop.notes.present? %>
                    <%
                      icons = []
                      icons << "📶" if shop.notes.include?("Wi-Fi")
                      icons << "🔌" if shop.notes.include?("充電器")
                      icons << "🚬" if shop.notes.match?(/喫煙|たばこ/)
                    %>
                    <% if icons.any? %>
                      <span class="text-[10px]"><%= icons.join(" ") %></span>
                    <% end %>
                  <% end %>
                </div>
              <% end %>
            <% end %>
          <% end %>
        </div>
      </div>

      <nav class="flex justify-center">
        <%= paginate @installed_shops, param_name: :shops_page %>
      </nav>
    <% else %>
      <div class="bg-card border border-border rounded-lg p-8 text-center">
        <div class="w-16 h-16 mx-auto mb-2">
          <%= image_tag "empty_search.svg", alt: "店舗なし", class: "w-full h-full opacity-50" %>
        </div>
        <% if params[:prefecture].present? %>
          <p class="text-muted-foreground text-sm">この都道府県に設置店舗はありません。</p>
          <%= link_to "全国で表示", machine_path(@machine_model.slug), class: "text-sm text-primary hover:underline mt-2 inline-block" %>
        <% else %>
          <p class="text-muted-foreground text-sm">設置店舗情報がありません。</p>
        <% end %>
      </div>
    <% end %>
  </div>
</section>
