<%# === Mobile Bottom Tab Bar (md以下で表示) === %>
<nav class="fixed bottom-0 inset-x-0 z-40 bg-background/95 backdrop-blur-md border-t border-border/50 md:hidden pb-[env(safe-area-inset-bottom)]"
     aria-label="メインナビゲーション">
  <div class="grid grid-cols-4 h-14">
    <%
      tabs = [
        { path: root_path, label: "ホーム", icon: "home", match: root_path },
        { path: search_path, label: "検索", icon: "search", match: search_path },
        { path: play_records_path, label: "収支", icon: "wallet", match: play_records_path },
        { path: voter_status_path, label: "マイ", icon: "user", match: voter_status_path },
      ]
    %>
    <% tabs.each do |tab| %>
      <%
        is_active = current_page?(tab[:match])
        color = is_active ? "text-primary" : "text-muted-foreground"
      %>
      <%= link_to tab[:path], class: "flex flex-col items-center justify-center gap-0.5 #{color} active:scale-95 transition-all duration-100", data: { turbo_frame: "_top" } do %>
        <% case tab[:icon] %>
        <% when "home" %>
          <svg class="w-5 h-5" fill="<%= is_active ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24" stroke-width="<%= is_active ? '0' : '1.5' %>">
            <path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        <% when "search" %>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="<%= is_active ? '2.5' : '1.5' %>">
            <path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        <% when "wallet" %>
          <svg class="w-5 h-5" fill="<%= is_active ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24" stroke-width="<%= is_active ? '0' : '1.5' %>">
            <path d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M12 8c1.11 0 2.08.402 2.599 1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        <% when "user" %>
          <svg class="w-5 h-5" fill="<%= is_active ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24" stroke-width="<%= is_active ? '0' : '1.5' %>">
            <path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        <% end %>
        <span class="text-[10px] font-medium leading-none"><%= tab[:label] %></span>
      <% end %>
    <% end %>
  </div>
</nav>
