<footer class="border-t border-border mt-12">
  <div class="mx-auto max-w-6xl px-4 py-6">
    <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-between">
      <%# Links %>
      <div class="flex items-center gap-4 text-sm">
        <%= link_to new_feedback_path,
              class: "text-muted-foreground transition-colors hover:text-foreground inline-flex items-center gap-1.5 py-2 min-h-[44px]" do %>
          <%= icon_message("w-4 h-4") %>
          ご意見・ご要望
        <% end %>
        <%= link_to new_shop_request_path,
              class: "text-muted-foreground transition-colors hover:text-foreground inline-flex items-center gap-1.5 py-2 min-h-[44px]" do %>
          <%= icon_plus_circle("w-4 h-4") %>
          店舗追加リクエスト
        <% end %>
      </div>

      <%# Copyright %>
      <div class="text-xs text-muted-foreground text-center sm:text-right">
        <p>&copy; <%= Date.current.year %> スロリセnavi</p>
        <p class="mt-0.5">パチスロリセット・設定判別の投票サイト</p>
      </div>
    </div>
  </div>
</footer>
