<header class="sticky top-0 z-50 w-full border-b border-border bg-background/80 backdrop-blur-sm"
        data-controller="mobile-nav">
  <div class="mx-auto flex h-14 max-w-6xl items-center justify-between px-4">
    <%# === Logo === %>
    <a href="/" class="flex items-center gap-2">
      <div class="flex h-8 w-8 items-center justify-center rounded-md bg-primary">
        <span class="text-sm font-bold text-primary-foreground">S</span>
      </div>
      <span class="text-lg font-semibold tracking-tight text-foreground">
        スロリセ<span class="text-primary">navi</span>
      </span>
    </a>

    <%# === Desktop Navigation === %>
    <nav class="hidden items-center gap-6 md:flex">
      <%= link_to "ホーム", root_path,
            class: "text-sm font-medium text-muted-foreground transition-colors hover:text-foreground" %>
      <%= link_to "検索", search_path,
            class: "text-sm font-medium text-muted-foreground transition-colors hover:text-foreground" %>
      <%= link_to "マイ", voter_status_path,
            class: "text-sm font-medium text-muted-foreground transition-colors hover:text-foreground" %>
    </nav>

    <%# === Right side: theme toggle + mobile menu === %>
    <div class="flex items-center gap-1">
      <%# Theme Toggle %>
      <div data-controller="theme">
        <button data-action="click->theme#toggle"
                class="inline-flex h-9 w-9 items-center justify-center rounded-md text-muted-foreground transition-colors hover:bg-secondary hover:text-foreground"
                title="テーマ切替">
          <span data-theme-target="icon">
            <%= icon_monitor("w-4 h-4") %>
          </span>
          <span class="sr-only">テーマを切り替え</span>
        </button>
      </div>

      <%# Mobile hamburger (md以下で表示) %>
      <button data-action="click->mobile-nav#toggle"
              class="inline-flex h-9 w-9 items-center justify-center rounded-md text-muted-foreground transition-colors hover:bg-secondary hover:text-foreground md:hidden"
              aria-label="メニューを開く">
        <%= icon_menu("w-5 h-5") %>
      </button>
    </div>
  </div>

  <%# === Mobile Drawer === %>
  <%# Overlay %>
  <div data-mobile-nav-target="overlay"
       data-action="click->mobile-nav#close"
       class="fixed inset-0 z-40 bg-black/50 opacity-0 pointer-events-none transition-opacity duration-300 md:hidden">
  </div>

  <%# Drawer panel %>
  <div data-mobile-nav-target="drawer"
       class="fixed top-0 right-0 z-50 h-full w-64 translate-x-full bg-background border-l border-border shadow-xl transition-transform duration-300 ease-in-out md:hidden">
    <div class="flex items-center justify-between p-4 border-b border-border">
      <span class="text-sm font-semibold text-foreground">メニュー</span>
      <button data-action="click->mobile-nav#close"
              class="inline-flex h-9 w-9 items-center justify-center rounded-md text-muted-foreground transition-colors hover:bg-secondary hover:text-foreground"
              aria-label="メニューを閉じる">
        <%= icon_x("w-5 h-5") %>
      </button>
    </div>

    <nav class="flex flex-col gap-1 p-4">
      <%= link_to root_path,
            class: "flex items-center gap-3 rounded-md px-3 py-3 text-base font-medium text-foreground transition-colors hover:bg-secondary min-h-[44px]" do %>
        <%= icon_home("w-5 h-5 text-muted-foreground") %>
        ホーム
      <% end %>
      <%= link_to search_path,
            class: "flex items-center gap-3 rounded-md px-3 py-3 text-base font-medium text-muted-foreground transition-colors hover:bg-secondary hover:text-foreground min-h-[44px]" do %>
        <%= icon_search("w-5 h-5 text-muted-foreground") %>
        検索
      <% end %>
      <%= link_to voter_status_path,
            class: "flex items-center gap-3 rounded-md px-3 py-3 text-base font-medium text-muted-foreground transition-colors hover:bg-secondary hover:text-foreground min-h-[44px]" do %>
        <%= icon_user("w-5 h-5 text-muted-foreground") %>
        マイステータス
      <% end %>

      <div class="my-2 border-t border-border"></div>

      <%= link_to new_feedback_path,
            class: "flex items-center gap-3 rounded-md px-3 py-3 text-sm font-medium text-muted-foreground transition-colors hover:bg-secondary hover:text-foreground min-h-[44px]" do %>
        <%= icon_message("w-5 h-5 text-muted-foreground") %>
        ご意見・ご要望
      <% end %>
      <%= link_to new_shop_request_path,
            class: "flex items-center gap-3 rounded-md px-3 py-3 text-sm font-medium text-muted-foreground transition-colors hover:bg-secondary hover:text-foreground min-h-[44px]" do %>
        <%= icon_plus_circle("w-5 h-5 text-muted-foreground") %>
        店舗追加リクエスト
      <% end %>
    </nav>
  </div>
</header>
