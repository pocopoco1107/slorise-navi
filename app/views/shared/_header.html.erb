<header class="bg-blue-800 dark:bg-gray-800 text-white shadow-md dark:shadow-gray-900/50">
  <div class="max-w-5xl mx-auto px-4 py-2 flex items-center justify-between">
    <a href="/" class="text-xl font-bold tracking-tight hover:text-blue-200 transition-colors duration-150 py-2 min-h-[44px] inline-flex items-center">
      スロリセnavi
    </a>
    <nav class="flex items-center gap-1 text-sm">
      <a href="/" class="hover:text-blue-200 hover:bg-blue-700/50 dark:hover:bg-gray-700/50 transition-all duration-150 px-3 py-2 rounded-md min-h-[44px] inline-flex items-center">ホーム</a>
