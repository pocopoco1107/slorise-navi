<% content_for(:title) { "店舗追加リクエスト - ヨミスロ" } %>

<section class="mt-4 max-w-lg mx-auto">
  <h1 class="text-xl font-bold text-foreground mb-4">店舗追加リクエスト</h1>

  <div class="bg-card border border-border rounded-lg p-5">
    <p class="text-sm text-muted-foreground mb-4">
      P-WORLDに掲載されていない店舗の追加をリクエストできます。<br>
      管理者が確認後、掲載いたします。
    </p>

    <%= form_with model: @shop_request, url: shop_requests_path, class: "space-y-4" do |f| %>
      <% if @shop_request.errors.any? %>
        <div class="rounded-lg border border-destructive/20 bg-destructive/5 p-3 text-sm text-destructive">
          <% @shop_request.errors.full_messages.each do |msg| %>
            <p><%= msg %></p>
          <% end %>
        </div>
      <% end %>

      <div>
        <label class="block text-sm font-medium text-foreground mb-1">都道府県 <span class="text-destructive">*</span></label>
        <%= f.collection_select :prefecture_id, @prefectures, :id, :name,
            { prompt: "選択してください" },
            class: "w-full border border-input bg-background text-foreground rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-ring focus:border-transparent" %>
      </div>

      <div>
        <label class="block text-sm font-medium text-foreground mb-1">店舗名 <span class="text-destructive">*</span></label>
        <%= f.text_field :name,
            placeholder: "例: スロットパーク新宿",
            class: "w-full border border-input bg-background text-foreground rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-ring focus:border-transparent placeholder:text-muted-foreground" %>
      </div>

      <div>
        <label class="block text-sm font-medium text-foreground mb-1">住所</label>
        <%= f.text_field :address,
            placeholder: "例: 東京都新宿区歌舞伎町1-1-1",
            class: "w-full border border-input bg-background text-foreground rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-ring focus:border-transparent placeholder:text-muted-foreground" %>
      </div>

      <div>
        <label class="block text-sm font-medium text-foreground mb-1">店舗公式サイトURL</label>
        <%= f.url_field :url,
            placeholder: "https://...",
            class: "w-full border border-input bg-background text-foreground rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-ring focus:border-transparent placeholder:text-muted-foreground" %>
      </div>

      <div>
        <label class="block text-sm font-medium text-foreground mb-1">補足情報</label>
        <%= f.text_area :note,
            rows: 3,
            placeholder: "店舗に関する補足があればお書きください（500文字以内）",
            class: "w-full border border-input bg-background text-foreground rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-ring focus:border-transparent resize-y placeholder:text-muted-foreground" %>
      </div>

      <div>
        <%= f.submit "リクエストを送信",
            class: "w-full bg-primary text-primary-foreground rounded-md px-4 py-2.5 text-sm font-medium hover:bg-primary/90 transition-colors cursor-pointer min-h-[44px]" %>
      </div>
    <% end %>
  </div>
</section>
