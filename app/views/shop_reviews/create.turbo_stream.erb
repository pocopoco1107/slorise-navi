<%= turbo_stream.replace "review_form" do %>
  <turbo-frame id="review_form">
    <div class="bg-green-50 dark:bg-green-900/30 border border-green-200 dark:border-green-700 rounded-lg p-4 mb-4">
      <p class="text-sm text-green-700 dark:text-green-400 font-medium">
        <%= @review.previously_new_record? ? "レビューを投稿しました！" : "レビューを更新しました！" %>
      </p>
      <p class="text-xs text-green-600 dark:text-green-500 mt-1">ページを再読み込みするとレビューが反映されます。</p>
    </div>
  </turbo-frame>
<% end %>

<% if @review.previously_new_record? %>
  <%= turbo_stream.prepend "reviews_list" do %>
    <%= render "shops/review_card", review: @review %>
  <% end %>

  <%= turbo_stream.remove "no_reviews" %>
<% else %>
  <%= turbo_stream.replace "review_#{@review.id}" do %>
    <%= render "shops/review_card", review: @review %>
  <% end %>
<% end %>
