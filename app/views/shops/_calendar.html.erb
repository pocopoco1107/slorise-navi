<%# Monthly calendar for shop vote activity — cells show vote count only %>
<%
  first_day = calendar_month.beginning_of_month
  last_day = calendar_month.end_of_month
  start_padding = first_day.wday
  end_padding = 6 - last_day.wday
  prev_month = calendar_month - 1.month
  next_month = calendar_month + 1.month
  today = Date.current
%>

<%# Month Navigation %>
<div class="flex items-center justify-center gap-4 mb-3">
  <%= link_to calendar_shop_path(shop.slug, month: prev_month.strftime("%Y-%m")),
      data: { turbo_frame: "shop_calendar" },
      class: "inline-flex items-center justify-center border border-border bg-background rounded-md w-10 h-10 text-foreground hover:bg-secondary active:scale-95 transition-all duration-150" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
  <% end %>
  <span class="font-bold text-foreground text-base tabular-nums">
    <%= calendar_month.strftime("%Y年%-m月") %>
  </span>
  <% if next_month.beginning_of_month <= today.beginning_of_month %>
    <%= link_to calendar_shop_path(shop.slug, month: next_month.strftime("%Y-%m")),
        data: { turbo_frame: "shop_calendar" },
        class: "inline-flex items-center justify-center border border-border bg-background rounded-md w-10 h-10 text-foreground hover:bg-secondary active:scale-95 transition-all duration-150" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
    <% end %>
  <% else %>
    <span class="inline-flex items-center justify-center border border-border bg-background rounded-md w-10 h-10 text-muted-foreground opacity-40">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
    </span>
  <% end %>
</div>

<%# Weekday Header %>
<div class="grid grid-cols-7 gap-px mb-1">
  <% %w[日 月 火 水 木 金 土].each_with_index do |day_name, i| %>
    <div class="text-center text-xs font-semibold py-1
      <%= case i when 0 then 'text-destructive' when 6 then 'text-chart-1' else 'text-muted-foreground' end %>">
      <%= day_name %>
    </div>
  <% end %>
</div>

<%# Calendar Grid %>
<div class="grid grid-cols-7 gap-px">
  <% start_padding.times do %>
    <div class="aspect-square"></div>
  <% end %>

  <% (first_day..last_day).each do |date| %>
    <%
      data = calendar_data[date]
      votes = data ? data[:votes] : 0
      is_today = date == today
      is_selected = defined?(current_date) && date == current_date
      is_future = date > today

      # Background intensity based on vote count
      bg_class = if votes > 0 && !is_future
        case votes
        when 1..4 then "bg-primary/5"
        when 5..9 then "bg-primary/10"
        else "bg-primary/[0.15]"
        end
      else
        ""
      end
    %>

    <% if is_future %>
      <div class="aspect-square flex flex-col items-center justify-center rounded-md opacity-30">
        <span class="text-[11px] tabular-nums leading-none
          <%= case date.wday when 0 then 'text-destructive' when 6 then 'text-chart-1' else 'text-muted-foreground' end %>">
          <%= date.day %>
        </span>
      </div>
    <% else %>
      <%= link_to date_shop_path(shop.slug, date: date.strftime("%Y-%m-%d"), anchor: "daily-summary"),
          data: { turbo_frame: "_top" },
          class: "aspect-square flex flex-col items-center justify-center rounded-md transition-colors
                  hover:bg-secondary active:bg-primary/10
                  #{bg_class}
                  #{'ring-2 ring-primary rounded-md' if is_today}
                  #{'bg-primary/20' if is_selected && !is_today}
                  #{'bg-destructive/5' if date.wday == 0 && !is_selected && votes == 0}
                  #{'bg-chart-1/5' if date.wday == 6 && !is_selected && votes == 0}" do %>
        <span class="text-[11px] tabular-nums leading-none
          <%= case date.wday when 0 then 'text-destructive' when 6 then 'text-chart-1' else 'text-muted-foreground' end %>
          <%= 'font-bold !text-primary' if is_today %>">
          <%= date.day %>
        </span>
        <% if votes > 0 %>
          <span class="text-[9px] font-bold tabular-nums leading-tight mt-0.5 text-foreground">
            <%= votes %>
          </span>
        <% end %>
      <% end %>
    <% end %>
  <% end %>

  <% end_padding.times do %>
    <div class="aspect-square"></div>
  <% end %>
</div>

<%# Selected date indicator %>
<% if defined?(current_date) %>
  <p class="text-center text-[10px] text-muted-foreground mt-2">
    <span class="font-medium text-foreground"><%= current_date.strftime("%-m/%-d") %>(<%= %w[日 月 火 水 木 金 土][current_date.wday] %>)</span>
    の記録を表示中
  </p>
<% end %>
