<div id="shop_events" class="mt-8">
  <h2 class="text-lg font-bold text-foreground mb-3 flex items-center gap-2">
    <span class="w-1 h-5 bg-primary rounded-full"></span>
    イベント・取材情報
  </h2>

  <%# === Event List === %>
  <div id="events_list" class="space-y-2 mb-4">
    <% if upcoming_events.any? || past_events.any? %>
      <% if upcoming_events.any? %>
        <p class="text-xs font-semibold text-primary mb-1">予定</p>
        <% upcoming_events.each do |event| %>
          <%= render "shops/event_item", event: event, label: :upcoming %>
        <% end %>
      <% end %>
      <% if past_events.any? %>
        <p class="text-xs font-semibold text-muted-foreground mb-1 <%= 'mt-3' if upcoming_events.any? %>">実績</p>
        <% past_events.each do |event| %>
          <%= render "shops/event_item", event: event, label: :past %>
        <% end %>
      <% end %>
    <% else %>
      <p class="text-sm text-muted-foreground text-center py-4" id="no_events">まだイベント情報はありません。</p>
    <% end %>
  </div>

  <%# === Event Post Form === %>
  <turbo-frame id="event_form">
    <details class="bg-card border border-border rounded-lg">
      <summary class="px-3 py-2.5 text-sm font-medium text-foreground cursor-pointer hover:bg-secondary rounded-lg transition-colors min-h-[44px] flex items-center gap-2">
        <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        イベント情報を投稿
      </summary>
      <div class="px-3 pb-3 pt-1">
        <%= form_with model: ShopEvent.new, url: shop_shop_events_path(shop), data: { turbo: true } do |f| %>
          <div class="grid grid-cols-2 gap-2 mb-2">
            <div>
              <label class="text-xs text-muted-foreground block mb-1">日付 <span class="text-destructive">*</span></label>
              <%= f.date_field :event_date, value: Date.current,
                  min: (Date.current - 30.days).to_s,
                  max: (Date.current + 60.days).to_s,
                  class: "w-full border border-input bg-background text-foreground rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-ring focus:border-transparent",
                  required: true %>
            </div>
            <div>
              <label class="text-xs text-muted-foreground block mb-1">種別 <span class="text-destructive">*</span></label>
              <%= f.select :event_type,
                  ShopEvent::EVENT_TYPE_LABELS.map { |k, v| [v, k] },
                  {},
                  class: "w-full border border-input bg-background text-foreground rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-ring focus:border-transparent",
                  required: true %>
            </div>
          </div>
          <div class="mb-2">
            <label class="text-xs text-muted-foreground block mb-1">タイトル <span class="text-destructive">*</span></label>
            <%= f.text_field :title, placeholder: "例: スロパチステーション取材",
                class: "w-full border border-input bg-background text-foreground rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-ring focus:border-transparent placeholder:text-muted-foreground",
                required: true, maxlength: 100 %>
          </div>
          <div class="mb-2">
            <label class="text-xs text-muted-foreground block mb-1">詳細（任意）</label>
            <%= f.text_area :description, placeholder: "補足情報があれば...", rows: 2,
                class: "w-full border border-input bg-background text-foreground rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-ring focus:border-transparent resize-none placeholder:text-muted-foreground",
                maxlength: 500 %>
          </div>
          <div class="mb-3">
            <label class="text-xs text-muted-foreground block mb-1">情報ソースURL（任意）</label>
            <%= f.url_field :source_url, placeholder: "https://...",
                class: "w-full border border-input bg-background text-foreground rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-ring focus:border-transparent placeholder:text-muted-foreground",
                maxlength: 500 %>
          </div>
          <button type="submit" class="w-full bg-primary text-primary-foreground rounded-md px-4 py-2.5 text-sm font-medium hover:bg-primary/90 active:scale-[0.98] transition-all duration-150 min-h-[44px]">
            投稿する（承認後に公開）
          </button>
        <% end %>
      </div>
    </details>
  </turbo-frame>
</div>
