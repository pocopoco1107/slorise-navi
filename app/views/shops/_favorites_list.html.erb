<% shops.each do |shop| %>
  <li class="py-1.5">
    <%= link_to shop_path(shop.slug), class: "flex justify-between items-center hover:bg-secondary -mx-2 px-2 py-2.5 rounded-md transition-colors duration-150 min-h-[44px]" do %>
      <span class="font-medium text-sm text-primary"><%= shop.name %></span>
      <span class="text-xs text-muted-foreground"><%= shop.prefecture.name %></span>
    <% end %>
  </li>
<% end %>
