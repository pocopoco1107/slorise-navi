<%= turbo_frame_tag "machine_vote_#{machine_model.id}" do %>
  <%
    has_reset_yes = user_vote&.reset_vote == 1
    has_reset_no  = user_vote&.reset_vote == 0
    user_confirmed = user_vote&.confirmed_setting || []

    selected_classes = {
      1 => 'bg-setting-1 text-white ring-1 ring-setting-1/50',
      2 => 'bg-setting-2 text-white ring-1 ring-setting-2/50',
      3 => 'bg-setting-3 text-white ring-1 ring-setting-3/50',
      4 => 'bg-setting-4 text-white ring-1 ring-setting-4/50',
      5 => 'bg-setting-5 text-white ring-1 ring-setting-5/50',
      6 => 'bg-setting-6 text-white ring-1 ring-setting-6/50'
    }
    unselected_classes = {
      1 => 'bg-setting-1/10 text-setting-1 hover:bg-setting-1/20',
      2 => 'bg-setting-2/10 text-setting-2 hover:bg-setting-2/20',
      3 => 'bg-setting-3/10 text-setting-3 hover:bg-setting-3/20',
      4 => 'bg-setting-4/10 text-setting-4 hover:bg-setting-4/20',
      5 => 'bg-setting-5/10 text-setting-5 hover:bg-setting-5/20',
      6 => 'bg-setting-6/10 text-setting-6 hover:bg-setting-6/20'
    }
  %>

  <div class="bg-card border border-border rounded-lg overflow-hidden h-full flex flex-col" data-controller="vote">

    <%# === Header: 機種名 + タイプバッジ + 台数 === %>
    <div class="px-3 py-2 border-b border-border bg-secondary/50">
      <div class="flex items-center gap-2">
        <% if machine_model.image_url.present? %>
          <img src="<%= machine_model.image_url %>"
               alt=""
               loading="lazy"
               class="w-8 h-8 object-contain rounded bg-secondary shrink-0"
               onerror="this.style.display='none'">
        <% end %>
        <%= link_to machine_path(machine_model.slug),
            class: "font-bold text-sm text-foreground hover:text-primary transition-colors truncate flex-1",
            data: { turbo_frame: "_top" } do %>
          <%= machine_model.name %>
        <% end %>
        <span class="text-[10px] font-bold px-1.5 py-0.5 rounded-md shrink-0 <%= machine_model.display_type_badge_class %>">
          <%= machine_model.display_type_label %>
        </span>
        <% if machine_model.generation_label %>
          <span class="text-[9px] font-bold px-1.5 py-0.5 rounded-md shrink-0 <%= machine_model.generation_badge_class %>">
            <%= machine_model.generation_label %>
          </span>
        <% end %>
        <% if defined?(unit_count) && unit_count %>
          <span class="text-[10px] text-muted-foreground shrink-0"><%= unit_count %>台</span>
        <% end %>
      </div>
    </div>

    <div class="px-3 py-2.5 space-y-2.5 flex-1">

      <%# === リセット判別 === %>
      <div>
        <p class="text-[10px] font-semibold text-muted-foreground uppercase tracking-wider mb-1">リセット判別</p>
        <div class="flex items-center gap-2">
          <div class="flex gap-1.5">
            <%= form_with url: votes_path, method: :post, data: { turbo: true, "vote-target": "form" }, class: "inline" do |f| %>
              <%= f.hidden_field :shop_id, value: shop.id %>
              <%= f.hidden_field :machine_model_id, value: machine_model.id %>
              <%= f.hidden_field :voted_on, value: date %>
              <%= f.hidden_field :reset_vote, value: 1 %>
              <button type="submit"
                      class="<%= has_reset_yes ? 'bg-vote-yes text-white ring-1 ring-vote-yes/50' : 'bg-vote-yes/10 text-vote-yes hover:bg-vote-yes/20' %> rounded-lg px-4 py-2 text-xs font-bold active:scale-95 transition-all duration-150 min-h-[36px]"
                      data-action="click->vote#submit"
                      data-vote-target="button">
                Yes
              </button>
            <% end %>
            <%= form_with url: votes_path, method: :post, data: { turbo: true, "vote-target": "form" }, class: "inline" do |f| %>
              <%= f.hidden_field :shop_id, value: shop.id %>
              <%= f.hidden_field :machine_model_id, value: machine_model.id %>
              <%= f.hidden_field :voted_on, value: date %>
              <%= f.hidden_field :reset_vote, value: 0 %>
              <button type="submit"
                      class="<%= has_reset_no ? 'bg-vote-no text-white ring-1 ring-vote-no/50' : 'bg-vote-no/10 text-vote-no hover:bg-vote-no/20' %> rounded-lg px-4 py-2 text-xs font-bold active:scale-95 transition-all duration-150 min-h-[36px]"
                      data-action="click->vote#submit"
                      data-vote-target="button">
                No
              </button>
            <% end %>
          </div>

          <%# リセット結果 %>
          <% if vote_summary && (vote_summary.reset_yes_count + vote_summary.reset_no_count) >= 3 %>
            <%
              total_reset = vote_summary.reset_yes_count + vote_summary.reset_no_count
              pct = (vote_summary.reset_yes_count.to_f / total_reset * 100).round
            %>
            <div class="flex items-center gap-1.5 flex-1 min-w-0">
              <div class="flex-1 h-1.5 bg-primary/20 rounded-full overflow-hidden">
                <div class="h-full rounded-full transition-all duration-500 <%= pct >= 50 ? 'bg-vote-yes' : 'bg-vote-no' %>"
                     style="width: <%= pct %>%"></div>
              </div>
              <span class="text-[11px] font-bold tabular-nums <%= pct >= 50 ? 'text-vote-yes' : 'text-vote-no' %> shrink-0"><%= pct %>%</span>
              <span class="text-[10px] text-muted-foreground shrink-0"><%= total_reset %>票</span>
            </div>
          <% else %>
            <span class="text-[10px] text-muted-foreground italic ml-1">データ不足</span>
          <% end %>
        </div>
      </div>

      <%# === 設定推測 === %>
      <div>
        <p class="text-[10px] font-semibold text-muted-foreground uppercase tracking-wider mb-1">設定推測</p>
        <div class="flex flex-wrap items-center gap-2">
          <div class="flex gap-1">
            <% (1..6).each do |setting| %>
              <%
                is_selected = user_vote&.setting_vote == setting
                color_class = is_selected ? selected_classes[setting] : unselected_classes[setting]
              %>
              <%= form_with url: votes_path, method: :post, data: { turbo: true, "vote-target": "form" }, class: "inline" do |f| %>
                <%= f.hidden_field :shop_id, value: shop.id %>
                <%= f.hidden_field :machine_model_id, value: machine_model.id %>
                <%= f.hidden_field :voted_on, value: date %>
                <%= f.hidden_field :setting_vote, value: setting %>
                <button type="submit"
                        class="<%= color_class %> rounded-lg w-9 h-9 text-xs font-bold active:scale-90 transition-all duration-150"
                        data-action="click->vote#submit"
                        data-vote-target="button"><%= setting %></button>
              <% end %>
            <% end %>
          </div>

          <%# 設定結果 %>
          <% if vote_summary && vote_summary.setting_avg.present? && vote_summary.total_votes >= 3 %>
            <%
              avg = vote_summary.setting_avg.to_f
              avg_color = case avg
                          when 0..2 then 'text-setting-1 bg-setting-1/10 border-setting-1/20'
                          when 2..4 then 'text-setting-4 bg-setting-4/10 border-setting-4/20'
                          else 'text-setting-6 bg-setting-6/10 border-setting-6/20'
                          end
            %>
            <div class="flex items-center gap-1.5">
              <span class="text-xs font-bold <%= avg_color %> border rounded-md px-2 py-0.5 tabular-nums">
                avg <%= vote_summary.setting_avg %>
              </span>
              <span class="text-[10px] text-muted-foreground"><%= vote_summary.total_votes %>票</span>
            </div>
          <% else %>
            <span class="text-[10px] text-muted-foreground italic">データ不足</span>
          <% end %>
        </div>

        <%# 設定分布バー %>
        <% if vote_summary && vote_summary.setting_distribution.present? && vote_summary.total_votes >= 3 %>
          <%
            dist = vote_summary.setting_distribution
            total = dist.values.map(&:to_i).sum
            total = 1 if total.zero?
            bar_colors = {
              1 => 'bg-setting-1', 2 => 'bg-setting-2',
              3 => 'bg-setting-3', 4 => 'bg-setting-4',
              5 => 'bg-setting-5', 6 => 'bg-setting-6'
            }
          %>
          <div class="flex items-end gap-0.5 mt-1.5 h-8">
            <% (1..6).each do |i| %>
              <%
                count = dist[i.to_s].to_i
                pct = (count.to_f / total * 100).round
                bar_h = [pct * 0.28, count > 0 ? 4 : 0].max
              %>
              <div class="flex flex-col items-center w-7">
                <div class="<%= bar_colors[i] %> w-full rounded-t transition-all duration-300"
                     style="height: <%= bar_h %>px"></div>
                <span class="text-[9px] font-medium text-muted-foreground leading-none mt-0.5 tabular-nums"><%= count %></span>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>

      <%# === 設定確定 === %>
      <div>
        <p class="text-[10px] font-semibold text-confirmed uppercase tracking-wider mb-1">確定情報</p>
        <div class="flex flex-wrap gap-1">
          <% Vote::CONFIRMED_SETTING_TAGS.each do |tag| %>
            <%
              is_selected = user_confirmed.include?(tag)
              btn_class = is_selected ? 'bg-confirmed text-white ring-1 ring-confirmed/50' : 'bg-confirmed/10 text-confirmed hover:bg-confirmed/20'
            %>
            <%= form_with url: votes_path, method: :post, data: { turbo: true, "vote-target": "form" }, class: "inline" do |f| %>
              <%= f.hidden_field :shop_id, value: shop.id %>
              <%= f.hidden_field :machine_model_id, value: machine_model.id %>
              <%= f.hidden_field :voted_on, value: date %>
              <%= f.hidden_field :confirmed_setting, value: tag %>
              <button type="submit"
                      class="<%= btn_class %> rounded-md px-3 py-1.5 text-[11px] font-bold active:scale-95 transition-all duration-150 min-h-[32px]"
                      data-action="click->vote#submit"
                      data-vote-target="button"><%= tag %></button>
            <% end %>
          <% end %>
        </div>
        <% if vote_summary && vote_summary.confirmed_setting_counts.present? && vote_summary.confirmed_setting_counts.values.sum > 0 %>
          <div class="flex flex-wrap gap-1 mt-1.5">
            <% vote_summary.confirmed_setting_counts.sort_by { |_, v| -v }.each do |tag, count| %>
              <% next if count.zero? %>
              <span class="text-[10px] bg-confirmed/10 text-confirmed border border-confirmed/20 rounded-md px-2 py-0.5 font-bold">
                <%= tag %> <span class="text-confirmed-light"><%= count %></span>
              </span>
            <% end %>
          </div>
        <% end %>
      </div>

    </div>
  </div>
<% end %>
