<div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-4" id="review_<%= review.id %>">
  <div class="flex items-center justify-between mb-2">
    <div class="flex items-center gap-2">
      <span class="text-yellow-400 text-sm"><%= render_stars(review.rating) %></span>
      <span class="text-xs font-bold px-2 py-0.5 rounded-full bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300"><%= review.category_label %></span>
    </div>
    <div class="flex items-center gap-2">
      <span class="text-xs text-gray-400"><%= review.created_at.strftime("%Y/%-m/%-d") %></span>
      <%= button_to reports_path, params: { report: { reportable_type: "ShopReview", reportable_id: review.id, reason: "inappropriate" } },
          method: :post, class: "text-xs text-gray-400 hover:text-red-500 transition-colors", data: { turbo: true, confirm: "このレビューを通報しますか？" } do %>
        通報
      <% end %>
    </div>
  </div>
  <% if review.title.present? %>
    <p class="text-sm font-bold text-gray-800 dark:text-gray-100 mb-1"><%= review.title %></p>
  <% end %>
  <p class="text-sm text-gray-700 dark:text-gray-200 whitespace-pre-wrap"><%= review.body %></p>
  <p class="text-xs text-gray-400 mt-2"><%= review.display_name %></p>
</div>
