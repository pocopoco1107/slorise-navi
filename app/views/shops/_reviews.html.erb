<div id="shop_reviews" class="mt-8">
  <div class="flex items-center gap-3 mb-4">
    <h2 class="text-lg font-bold text-foreground">レビュー</h2>
    <% if reviews.any? %>
      <div class="flex items-center gap-1">
        <span class="text-yellow-400 text-lg"><%= render_stars(average_rating) %></span>
        <span class="text-sm font-bold text-foreground"><%= average_rating %></span>
        <span class="text-xs text-muted-foreground">(<%= reviews.size %>件)</span>
      </div>
    <% end %>
  </div>

  <!-- Review Form -->
  <turbo-frame id="review_form">
    <div class="bg-card border border-border rounded-lg p-4 mb-4">
      <h3 class="text-sm font-bold text-foreground mb-3">
        <%= existing_review ? "レビューを編集" : "レビューを投稿" %>
      </h3>
      <div id="review_form_errors"></div>
      <%= form_with model: (existing_review || ShopReview.new), url: shop_shop_reviews_path(shop), data: { turbo: true } do |f| %>
        <!-- Star Rating -->
        <div class="mb-3" data-controller="star-rating">
          <label class="text-xs text-muted-foreground block mb-1">評価 <span class="text-destructive">*</span></label>
          <%= f.hidden_field :rating, data: { star_rating_target: "input" } %>
          <div class="flex gap-1" data-action="mouseleave->star-rating#reset">
            <% 5.times do |i| %>
              <button type="button"
                      data-star-rating-target="star"
                      data-value="<%= i + 1 %>"
                      data-action="click->star-rating#select mouseenter->star-rating#hover"
                      class="text-2xl cursor-pointer hover:scale-110 transition-transform text-muted-foreground min-w-[44px] min-h-[44px] inline-flex items-center justify-center">
                &#9734;
              </button>
            <% end %>
          </div>
        </div>

        <!-- Category -->
        <div class="mb-3">
          <label class="text-xs text-muted-foreground block mb-1">カテゴリ</label>
          <%= f.select :category,
              ShopReview::CATEGORY_LABELS.map { |k, v| [v, k] },
              {},
              class: "w-full border border-input bg-background text-foreground rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-ring focus:border-transparent" %>
        </div>

        <!-- Title -->
        <div class="mb-3">
          <%= f.text_field :title, placeholder: "タイトル（任意、50文字以内）",
              class: "w-full border border-input bg-background text-foreground rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-ring focus:border-transparent placeholder:text-muted-foreground" %>
        </div>

        <!-- Body -->
        <div class="mb-3">
          <%= f.text_area :body, placeholder: "レビュー本文（必須、500文字以内）", rows: 3,
              class: "w-full border border-input bg-background text-foreground rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-ring focus:border-transparent resize-none placeholder:text-muted-foreground" %>
        </div>

        <!-- Reviewer Name -->
        <div class="mb-3">
          <%= f.text_field :reviewer_name, placeholder: "名前（任意、デフォルト「名無し」）",
              class: "w-full border border-input bg-background text-foreground rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-ring focus:border-transparent placeholder:text-muted-foreground" %>
        </div>

        <button type="submit" class="bg-primary text-primary-foreground rounded-md px-6 py-2 text-sm font-medium hover:bg-primary/90 active:scale-95 transition-all duration-150 min-h-[44px]">
          <%= existing_review ? "更新する" : "投稿する" %>
        </button>
      <% end %>
    </div>
  </turbo-frame>

  <!-- Reviews List -->
  <div id="reviews_list" class="space-y-3">
    <% display_reviews = reviews.first(5) %>
    <% if display_reviews.any? %>
      <% display_reviews.each do |review| %>
        <%= render "shops/review_card", review: review %>
      <% end %>
      <% if reviews.size > 5 %>
        <div id="reviews_more" data-controller="accordion">
          <button type="button" data-action="click->accordion#toggle"
                  class="w-full text-center text-sm text-primary hover:text-primary/80 font-medium py-3 border border-border rounded-lg hover:bg-secondary transition-colors min-h-[44px]">
            もっと見る (<%= reviews.size - 5 %>件)
            <svg data-accordion-target="icon" class="w-4 h-4 inline ml-1 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div data-accordion-target="content" class="hidden mt-3 space-y-3">
            <% reviews.drop(5).each do |review| %>
              <%= render "shops/review_card", review: review %>
            <% end %>
          </div>
        </div>
      <% end %>
    <% else %>
      <p class="text-sm text-muted-foreground text-center py-4" id="no_reviews">まだレビューはありません。最初のレビューを投稿しましょう。</p>
    <% end %>
  </div>
</div>
