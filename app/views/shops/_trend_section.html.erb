<%#
  Trend section with period tabs + weekly summary
  Local variables:
    shop       - Shop instance
    trend_data - Array of trend hashes (7-day default)
    weekly_summary - Hash with weekly summary data
%>
<div class="mt-8">
  <div class="bg-card border border-border rounded-lg p-4 mb-4">
    <div class="flex items-center justify-between mb-3">
      <h2 class="text-sm font-bold text-foreground flex items-center gap-2">
        <span class="w-1 h-4 bg-chart-1 rounded-full"></span>
        記録トレンド
      </h2>

      <%# Period tabs %>
      <div data-controller="trend-tab"
           data-trend-tab-url-value="<%= trend_data_shop_path(shop.slug) %>"
           data-trend-tab-current-value="7"
           class="flex gap-1">
        <% [
          ["7", "7日"],
          ["30", "30日"],
          ["all", "全期間"]
        ].each do |period, label| %>
          <button data-trend-tab-target="tab"
                  data-period="<%= period %>"
                  data-action="click->trend-tab#switch"
                  class="px-2.5 py-1 text-[11px] font-medium rounded-md transition-all duration-150 min-h-[32px]
                         <%= period == '7' ? 'bg-primary text-primary-foreground' : 'bg-secondary text-secondary-foreground hover:bg-secondary/80' %>">
            <%= label %>
          </button>
        <% end %>
      </div>
    </div>

    <%# Chart area (Turbo Frame for dynamic updates) %>
    <%= render "shops/trend_chart_frame",
        trend_data: trend_data,
        period: "7",
        shop: shop %>
  </div>

  <%# === Weekly Summary === %>
  <% if weekly_summary[:total_votes].to_i > 0 %>
    <%= render "shops/weekly_summary", summary: weekly_summary %>
  <% end %>
</div>
