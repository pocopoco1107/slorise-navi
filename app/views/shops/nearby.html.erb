<turbo-frame id="nearby_results">
  <% if @error.present? %>
    <div class="mt-3 rounded-lg border border-destructive/30 bg-destructive/5 p-4">
      <p class="text-sm text-destructive"><%= @error %></p>
    </div>
  <% elsif @nearby_shops.blank? && @imprecise_shops.blank? %>
    <div class="mt-3 rounded-lg border border-border bg-card p-6 text-center">
      <svg class="mx-auto h-10 w-10 text-muted-foreground/40 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
        <path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <p class="text-sm text-muted-foreground">半径10km以内に店舗が見つかりませんでした</p>
      <p class="text-xs text-muted-foreground mt-1">都道府県から探してみてください</p>
    </div>
  <% else %>
    <div class="mt-3">
      <div class="flex items-center gap-2 mb-3">
        <svg class="h-4 w-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <h3 class="text-sm font-semibold text-foreground">近くの店舗 (<%= @nearby_shops.size %>件)</h3>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <% @nearby_shops.each do |shop| %>
          <%= link_to shop_path(shop.slug), class: "group rounded-lg border border-border bg-card p-3 hover:border-primary/50 hover:bg-secondary transition-all duration-150 block", data: { turbo_frame: "_top" } do %>
            <div class="flex items-start justify-between gap-2">
              <p class="font-medium text-sm text-foreground truncate flex-1 group-hover:text-primary transition-colors"><%= shop.name %></p>
              <span class="shrink-0 text-xs font-semibold tabular-nums text-primary bg-primary/10 px-1.5 py-0.5 rounded-full">
                <%= "%.1f" % shop.distance_km %>km
              </span>
            </div>
            <p class="text-xs text-muted-foreground mt-1"><%= shop.prefecture&.name %></p>
            <div class="flex flex-wrap items-center gap-1 mt-1">
              <% if shop.slot_rates.present? %>
                <% shop.slot_rates.each do |rate| %>
                  <span class="bg-primary/10 text-primary text-[10px] font-medium px-1.5 py-0.5 rounded-full"><%= rate %></span>
                <% end %>
              <% end %>
              <% if shop.exchange_rate != "unknown_rate" %>
                <span class="text-[10px] font-bold px-1.5 py-0.5 rounded-full
                  <%= case shop.exchange_rate
                      when 'equal_rate' then 'bg-primary/10 text-primary'
                      when 'rate_56' then 'bg-chart-4/10 text-chart-4'
                      when 'rate_50' then 'bg-chart-5/10 text-chart-5'
                      when 'non_equal' then 'bg-muted text-muted-foreground'
                      end %>">
                  <%= shop.exchange_rate_display %>
                </span>
              <% end %>
              <% if shop.address.present? %>
                <span class="text-[10px] text-muted-foreground truncate max-w-[200px]"><%= shop.address %></span>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </div>

      <% if @imprecise_shops.present? %>
        <div class="mt-4 pt-4 border-t border-border">
          <p class="text-xs text-muted-foreground mb-2">おおよその位置（距離が不正確な場合があります）</p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
            <% @imprecise_shops.each do |shop| %>
              <%= link_to shop_path(shop.slug), class: "group rounded-lg border border-border/50 bg-card/50 p-2.5 hover:border-primary/50 hover:bg-secondary transition-all duration-150 block opacity-70", data: { turbo_frame: "_top" } do %>
                <div class="flex items-start justify-between gap-2">
                  <p class="font-medium text-xs text-foreground truncate flex-1 group-hover:text-primary transition-colors"><%= shop.name %></p>
                  <span class="shrink-0 text-[10px] tabular-nums text-muted-foreground bg-muted px-1.5 py-0.5 rounded-full">
                    ~<%= "%.0f" % shop.distance_km %>km
                  </span>
                </div>
                <p class="text-[10px] text-muted-foreground mt-0.5"><%= shop.prefecture&.name %></p>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</turbo-frame>
