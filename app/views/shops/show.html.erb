<% content_for(:title) { "#{@shop.name} - スロリセnavi" } %>

<section class="mt-4">
  <div class="mb-3">
    <%= link_to "← #{@shop.prefecture.name}に戻る", prefecture_path(@shop.prefecture.slug), class: "text-sm text-primary hover:underline inline-flex items-center min-h-[44px] py-2 transition-colors duration-150" %>
  </div>

  <!-- Shop Info -->
  <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-4 mb-4">
    <div class="flex items-center gap-2">
      <h1 class="text-xl font-bold text-gray-800 dark:text-gray-100 flex-1"><%= @shop.name %></h1>
      <div data-controller="favorite" data-favorite-shop-slug-value="<%= @shop.slug %>">
        <button data-action="click->favorite#toggle"
                class="text-2xl leading-none p-1 hover:scale-110 transition-transform"
                title="お気に入り">
          <span data-favorite-star class="text-gray-400">☆</span>
        </button>
      </div>
    </div>
    <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">
      <%= @shop.prefecture.name %>
      <% if @shop.address.present? %>
        / <%= @shop.address %>
      <% end %>
    </p>
    <div class="flex flex-wrap items-center gap-3 mt-1.5 text-xs text-gray-500 dark:text-gray-400">
      <% if @shop.phone_number.present? %>
        <a href="tel:<%= @shop.phone_number %>" class="hover:text-blue-600">📞 <%= @shop.phone_number %></a>
      <% end %>
      <% if @shop.access_info.present? %>
        <span>🚃 <%= @shop.access_info %></span>
      <% end %>
      <% if @shop.pworld_url.present? %>
        <a href="<%= @shop.pworld_url %>" target="_blank" rel="noopener" class="text-blue-600 dark:text-blue-400 hover:underline">P-WORLD →</a>
      <% end %>
    </div>
  </div>

  <!-- Shop Info Card -->
  <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-4 mb-6">
    <h2 class="text-sm font-bold text-gray-700 dark:text-gray-200 mb-3 border-b border-gray-100 dark:border-gray-700 pb-2">店舗情報</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-y-3 gap-x-4 text-sm">
      <div>
        <span class="text-xs text-gray-500 dark:text-gray-400 block">レート</span>
        <span class="font-medium"><%= @shop.slot_rates_display %></span>
      </div>
      <div>
        <span class="text-xs text-gray-500 dark:text-gray-400 block">換金率</span>
        <span class="font-medium"><%= @shop.exchange_rate_display %></span>
      </div>
      <div>
        <span class="text-xs text-gray-500 dark:text-gray-400 block">スロット台数</span>
        <span class="font-medium"><%= @shop.slot_machines || "未設定" %><%= "台" if @shop.slot_machines %></span>
      </div>
      <div>
        <span class="text-xs text-gray-500 dark:text-gray-400 block">総台数</span>
        <span class="font-medium"><%= @shop.total_machines || "未設定" %><%= "台" if @shop.total_machines %></span>
      </div>
      <div>
        <span class="text-xs text-gray-500 dark:text-gray-400 block">営業時間</span>
        <span class="font-medium"><%= @shop.business_hours || "未設定" %></span>
      </div>
      <% if @shop.parking_spaces.present? %>
        <div>
          <span class="text-xs text-gray-500 dark:text-gray-400 block">駐車場</span>
          <span class="font-medium"><%= @shop.parking_spaces %>台</span>
        </div>
      <% end %>
      <% if @shop.opened_on.present? %>
        <div>
          <span class="text-xs text-gray-500 dark:text-gray-400 block">オープン日</span>
          <span class="font-medium"><%= @shop.opened_on.strftime("%Y年%m月%d日") %></span>
        </div>
      <% end %>
      <% if @shop.former_event_days.present? %>
        <div class="col-span-2 sm:col-span-3">
          <span class="text-xs text-gray-500 dark:text-gray-400 block">旧イベント日</span>
          <span class="font-medium text-red-600"><%= @shop.former_event_days %></span>
        </div>
      <% end %>
      <% if @shop.morning_entry.present? %>
        <div class="col-span-2 sm:col-span-3">
          <span class="text-xs text-gray-500 dark:text-gray-400 block">朝の入場</span>
          <span class="font-medium text-blue-700"><%= @shop.morning_entry %></span>
        </div>
      <% end %>
      <% if @shop.features.present? %>
        <div class="col-span-2 sm:col-span-3">
          <span class="text-xs text-gray-500 dark:text-gray-400 block">特徴</span>
          <span class="font-medium"><%= @shop.features %></span>
        </div>
      <% end %>
    </div>
    <% if @shop.notes.present? %>
      <%
        display_map = {
          "Wi-Fi" => ["📶", "Wi-Fi", ""],
          "充電器" => ["🔌", "充電器", ""],
          "屋内喫煙室" => ["🚬", "喫煙室あり", ""],
          "加熱式たばこ遊技OK" => ["🚬", "加熱式たばこ遊技中OK", "bg-green-50 text-green-700 border-green-200"],
          "加熱式たばこ喫煙室" => ["🚬", "加熱式たばこ(喫煙室)", ""],
          "加熱式たばこ" => ["🚬", "加熱式たばこ", ""],
          "出玉公開" => ["📊", "出玉公開", ""],
        }
      %>
      <div class="mt-3 pt-3 border-t border-gray-100 dark:border-gray-700">
        <span class="text-xs text-gray-500 dark:text-gray-400 block mb-1.5">設備</span>
        <div class="flex flex-wrap gap-1.5">
          <% @shop.notes.split("、").each do |facility| %>
            <% next unless display_map.key?(facility) %>
            <% icon, label, extra_class = display_map[facility] %>
            <span class="inline-flex items-center gap-1 text-xs px-2 py-1 rounded-full border <%= extra_class.present? ? extra_class : 'bg-gray-50 text-gray-600 border-gray-100' %>">
              <%= icon %> <%= label %>
            </span>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Date Navigation -->
  <div class="flex items-center justify-center gap-3 mb-4">
    <%= link_to date_shop_path(@shop.slug, date: (@date - 1.day).strftime("%Y-%m-%d")),
        class: "bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-md px-4 py-2 text-sm hover:bg-gray-50 dark:hover:bg-gray-700 active:scale-95 transition-all duration-150 min-h-[44px] inline-flex items-center" do %>
      &#9664; 前日
    <% end %>
    <span class="font-bold text-sm">
      <%= @date.strftime("%Y年%-m月%-d日") %>
      <% if @date == Date.current %>
        <span class="text-primary">(今日)</span>
      <% end %>
    </span>
    <% if @date < Date.current %>
      <%= link_to date_shop_path(@shop.slug, date: (@date + 1.day).strftime("%Y-%m-%d")),
          class: "bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-md px-4 py-2 text-sm hover:bg-gray-50 dark:hover:bg-gray-700 active:scale-95 transition-all duration-150 min-h-[44px] inline-flex items-center" do %>
        翌日 &#9654;
      <% end %>
    <% end %>
    <% unless @date == Date.current %>
      <%= link_to "今日", shop_path(@shop.slug),
          class: "bg-primary text-white rounded-md px-4 py-2 text-sm hover:bg-primary-light active:scale-95 transition-all duration-150 min-h-[44px] inline-flex items-center" %>
    <% end %>
  </div>

  <!-- Vote Errors -->
  <div id="vote_errors"></div>

  <!-- Machine Search (add new vote) -->
  <div data-controller="machine-search"
       data-machine-search-shop-id-value="<%= @shop.id %>"
       data-machine-search-date-value="<%= @date %>"
       class="mb-4">
    <div class="relative">
      <input type="text"
             data-machine-search-target="input"
             data-action="input->machine-search#search"
             placeholder="機種名を検索して投票..."
             class="w-full border border-gray-300 dark:border-gray-600 dark:bg-gray-800 dark:text-gray-100 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent shadow-sm dark:shadow-none dark:placeholder-gray-400"
             autocomplete="off">
    </div>
    <div data-machine-search-target="results"
         class="mt-2 bg-white border border-gray-200 rounded-lg shadow-sm empty:hidden p-3"></div>
  </div>

  <!-- Machine Filter -->
  <div class="mb-3" data-controller="machine-filter">
    <div class="flex items-center gap-2 flex-wrap">
      <input type="text" placeholder="機種名で絞り込み..."
             data-machine-filter-target="input"
             data-action="input->machine-filter#filter"
             class="flex-1 min-w-[160px] border border-gray-200 dark:border-gray-600 dark:bg-gray-800 dark:text-gray-100 rounded-md px-3 py-1.5 text-xs focus:outline-none focus:ring-1 focus:ring-blue-400 dark:placeholder-gray-400">
    </div>
  </div>

  <!-- Voted Machines -->
  <div class="mb-8" data-machine-filter-target="list">
    <% if @machine_models.any? %>
      <h2 class="text-sm font-semibold text-gray-600 dark:text-gray-300 mb-2">設置機種 (<%= @machine_models.size %>件)</h2>
      <%
        # タイプ別にグループ化
        grouped = @machine_models.chunk { |m| m.display_type }
      %>
      <% grouped.each do |type, machines| %>
        <div class="flex items-center gap-2 mt-4 mb-2" data-type-header>
          <span class="text-[11px] font-bold px-2 py-0.5 rounded-full <%= machines.first.display_type_badge_class %>">
            <%= machines.first.display_type_label %>
          </span>
          <span class="text-[10px] text-gray-400"><%= machines.size %>機種</span>
          <div class="flex-1 h-px bg-gray-200 dark:bg-gray-700"></div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
          <% machines.each do |machine_model| %>
            <%= render "shops/machine_vote_row",
                machine_model: machine_model,
                vote_summary: @vote_summaries[machine_model.id],
                user_vote: @user_votes[machine_model.id],
                shop: @shop,
                date: @date,
                unit_count: @unit_counts[machine_model.id] %>
          <% end %>
        </div>
      <% end %>
    <% else %>
      <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-8 text-center">
        <div class="w-20 h-20 mx-auto mb-3">
          <%= image_tag "empty_search.svg", alt: "投票なし", class: "w-full h-full opacity-50" %>
        </div>
        <p class="text-gray-500 text-sm">まだ投票がありません。上の検索から機種を探して投票しましょう。</p>
      </div>
    <% end %>
  </div>

  <!-- Reviews -->
  <%= render "shops/reviews", shop: @shop, reviews: @reviews, average_rating: @average_rating, existing_review: @existing_review %>

  <!-- Comments -->
  <%= render "shops/comments", shop: @shop, comments: @comments, date: @date %>

  <!-- Trend Chart -->
  <% if @trend_data&.any? { |d| d[:votes] > 0 } %>
    <div class="mt-8">
      <%= render "shared/trend_chart",
          title: "過去7日間の投票トレンド",
          days_data: @trend_data %>
    </div>
  <% end %>

  <!-- Same Rate Shops -->
  <% if @same_rate_shops.present? %>
    <div class="mt-8">
      <h2 class="text-sm font-bold text-gray-700 dark:text-gray-200 mb-2 border-l-4 border-green-500 pl-2">
        <%= @shop.prefecture.name %>の同レート店舗
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
        <% @same_rate_shops.each do |other_shop| %>
          <%= link_to shop_path(other_shop.slug), class: "bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg px-3 py-2.5 hover:shadow-md hover:-translate-y-0.5 active:scale-[0.98] transition-all duration-150 block min-h-[44px]" do %>
            <span class="text-sm font-medium text-primary dark:text-blue-400"><%= other_shop.name %></span>
            <div class="flex flex-wrap items-center gap-1 mt-1">
              <% if other_shop.slot_rates.present? %>
                <% other_shop.slot_rates.each do |rate| %>
                  <span class="bg-blue-50 dark:bg-blue-900/40 text-blue-700 dark:text-blue-400 text-[10px] px-1.5 py-0.5 rounded-full"><%= rate %></span>
                <% end %>
              <% end %>
              <% if other_shop.exchange_rate != "unknown_rate" %>
                <span class="text-[10px] text-gray-500"><%= other_shop.exchange_rate_display %></span>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>
</section>
