<% content_for(:title) { "マイステータス | ヨミスロ" } %>

<section class="max-w-2xl mx-auto">
  <h1 class="text-lg font-bold text-foreground mb-4 flex items-center gap-2">
    <span class="w-1 h-5 bg-primary rounded-full"></span>
    マイステータス
  </h1>

  <% if @has_votes %>
    <!-- トークンバックアップ (目立つ位置に) -->
    <% unless @profile.display_name.present? %>
      <div class="bg-slot-yellow/10 border border-slot-yellow/30 rounded-lg p-3 mb-4">
        <div class="flex items-start gap-2">
          <span class="text-lg leading-none mt-0.5">⚠️</span>
          <div class="flex-1 min-w-0">
            <p class="text-xs font-semibold text-foreground">トークンを控えておこう</p>
            <p class="text-[11px] text-muted-foreground mt-0.5">Cookieが消えるとデータにアクセスできなくなります。</p>
            <div class="flex items-center gap-2 mt-2" data-controller="clipboard">
              <code class="flex-1 bg-secondary text-foreground text-[11px] px-2 py-1.5 rounded font-mono select-all overflow-x-auto" data-clipboard-target="source"><%= cookies[:voter_token] %></code>
              <button type="button" data-clipboard-target="button" data-action="click->clipboard#copy"
                      class="shrink-0 bg-primary text-primary-foreground px-3 py-1.5 rounded text-xs font-medium hover:bg-primary/90 active:scale-95 transition-all min-h-[36px]">
                コピー
              </button>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <!-- Voter Identity + Display Name -->
    <div class="bg-card rounded-lg border-b border-border/50 p-4 mb-4">
      <div class="flex items-center justify-between gap-3">
        <div class="min-w-0">
          <p class="text-xl font-bold text-primary truncate"><%= @voter_label %></p>
          <p class="text-[11px] text-muted-foreground mt-0.5">ID: <%= cookies[:voter_token]&.last(4) %></p>
        </div>
        <div class="flex items-center gap-2">
          <span class="stat-number text-lg text-slot-yellow"><%= @profile.points %></span>
          <span class="text-xs text-muted-foreground">pt</span>
        </div>
      </div>

      <!-- Display Name Form -->
      <div class="mt-3 pt-3 border-t border-border/50">
        <%= form_tag voter_display_name_path, method: :patch, class: "flex items-center gap-2" do %>
          <input type="text" name="display_name" value="<%= @profile.display_name %>"
                 placeholder="ユーザー名を設定 (+<%= VoterProfile::POINT_RULES[:display_name_set] %>pt)"
                 maxlength="20"
                 class="flex-1 min-w-0 border border-input bg-background text-foreground rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-ring placeholder:text-muted-foreground min-h-[40px]">
          <button type="submit" class="shrink-0 bg-secondary text-secondary-foreground px-3 py-2 rounded-md text-xs font-medium hover:bg-secondary/80 active:scale-95 transition-all min-h-[40px]">
            保存
          </button>
        <% end %>
      </div>
    </div>

    <!-- 称号 + ポイント進捗 -->
    <div class="bg-card rounded-lg border-l-2 border-l-slot-yellow p-4 mb-4">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-[10px] text-muted-foreground uppercase tracking-wider">称号</p>
          <p class="text-xl font-bold text-foreground mt-0.5"><%= @profile.rank_title %></p>
        </div>
      </div>
      <% next_rank = VoterProfile.next_rank_for(@profile) %>
      <% if next_rank %>
        <div class="mt-3">
          <div class="flex items-center justify-between text-[10px] text-muted-foreground mb-1">
            <span>次: <%= next_rank[:title] %></span>
            <span>あと<%= next_rank[:points_needed] %>pt<%= " / 的中率#{next_rank[:accuracy_needed]}%以上" if next_rank[:accuracy_needed] %></span>
          </div>
          <%
            current_rank_idx = VoterProfile::RANK_TITLES.index { |r| r[:title] == @profile.rank_title }
            current_min = current_rank_idx ? VoterProfile::RANK_TITLES[current_rank_idx][:min_points] : 0
            next_min = VoterProfile::RANK_TITLES.find { |r| r[:title] == next_rank[:title] }&.dig(:min_points) || 0
            range = [next_min - current_min, 1].max
            progress = [(@profile.points - current_min).to_f / range * 100, 100].min
          %>
          <div class="h-1.5 bg-secondary rounded-full overflow-hidden">
            <div class="h-full bg-primary rounded-full transition-all" style="width: <%= progress %>%"></div>
          </div>
        </div>
      <% end %>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-2 mb-4">
      <div class="bg-surface-inset rounded-lg p-3 text-center">
        <p class="stat-number text-xl text-primary"><%= @total_votes_count %></p>
        <p class="text-[10px] text-muted-foreground mt-0.5">設定記録</p>
      </div>
      <div class="bg-surface-inset rounded-lg p-3 text-center">
        <p class="stat-number text-xl text-primary"><%= @play_records_count %></p>
        <p class="text-[10px] text-muted-foreground mt-0.5">収支記録</p>
      </div>
      <div class="bg-surface-inset rounded-lg p-3 text-center">
        <p class="stat-number text-xl text-primary"><%= @shops_count %></p>
        <p class="text-[10px] text-muted-foreground mt-0.5">記録店舗</p>
      </div>
      <div class="bg-surface-inset rounded-lg p-3 text-center">
        <p class="stat-number text-xl text-primary"><%= @prefectures_count %></p>
        <p class="text-[10px] text-muted-foreground mt-0.5">記録都道府県</p>
      </div>
    </div>

    <!-- ポイントの貯め方 -->
    <div class="bg-card rounded-lg border-b border-border/50 p-4 mb-4">
      <h2 class="text-sm font-bold text-foreground mb-3 flex items-center gap-2">
        <span class="w-1 h-4 bg-slot-yellow rounded-full"></span>
        ポイントの貯め方
      </h2>
      <div class="grid grid-cols-2 gap-x-4 gap-y-1.5 text-xs">
        <div class="flex items-center justify-between">
          <span class="text-muted-foreground">設定/リセット記録</span>
          <span class="font-bold text-slot-yellow tabular-nums">+<%= VoterProfile::POINT_RULES[:vote] %>pt</span>
        </div>
        <div class="flex items-center justify-between">
          <span class="text-muted-foreground">確定情報の記録</span>
          <span class="font-bold text-slot-yellow tabular-nums">+<%= VoterProfile::POINT_RULES[:confirmed_setting] %>pt</span>
        </div>
        <div class="flex items-center justify-between">
          <span class="text-muted-foreground">収支記録</span>
          <span class="font-bold text-slot-yellow tabular-nums">+<%= VoterProfile::POINT_RULES[:play_record] %>pt</span>
        </div>
        <div class="flex items-center justify-between">
          <span class="text-muted-foreground">ご意見・要望</span>
          <span class="font-bold text-slot-yellow tabular-nums">+<%= VoterProfile::POINT_RULES[:feedback] %>pt</span>
        </div>
        <div class="flex items-center justify-between">
          <span class="text-muted-foreground">ユーザー名設定</span>
          <span class="font-bold text-slot-yellow tabular-nums">+<%= VoterProfile::POINT_RULES[:display_name_set] %>pt</span>
        </div>
        <div class="flex items-center justify-between">
          <span class="text-muted-foreground">7日連続記録</span>
          <span class="font-bold text-slot-yellow tabular-nums">+<%= VoterProfile::POINT_RULES[:streak_7] %>pt</span>
        </div>
        <div class="flex items-center justify-between">
          <span class="text-muted-foreground">3県以上で記録</span>
          <span class="font-bold text-slot-yellow tabular-nums">+<%= VoterProfile::POINT_RULES[:multi_prefecture] %>pt</span>
        </div>
      </div>
    </div>

    <!-- ストリーク -->
    <div class="bg-card rounded-lg border-b border-border/50 p-4 mb-4">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-sm font-bold text-foreground flex items-center gap-2">
          <span class="w-1 h-4 bg-slot-red rounded-full"></span>
          連続記録ストリーク
        </h2>
        <div class="flex items-center gap-1.5">
          <span class="text-2xl">🔥</span>
          <span class="text-xl font-bold tabular-nums text-foreground"><%= @profile.current_streak %></span>
          <span class="text-xs text-muted-foreground">日連続</span>
        </div>
      </div>
      <div class="flex items-center justify-between gap-1">
        <% @streak_days.each do |day| %>
          <div class="flex flex-col items-center gap-1">
            <span class="text-[10px] text-muted-foreground"><%= day[:label] %></span>
            <div class="w-8 h-8 rounded-full flex items-center justify-center
              <%= day[:voted] ? 'bg-primary text-primary-foreground' : 'bg-secondary' %>">
              <% if day[:voted] %>
                <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
      <% if @profile.max_streak > @profile.current_streak %>
        <p class="text-xs text-muted-foreground mt-2 text-center">最長記録: <%= @profile.max_streak %>日連続</p>
      <% end %>
    </div>

    <!-- 的中率 -->
    <% if @profile.accuracy_majority.present? || @profile.high_setting_rate.present? %>
      <%
        accuracy_cards = []
        accuracy_cards << { value: @profile.accuracy_confirmed, color: "text-confirmed", label: "確定一致率" } if @profile.accuracy_confirmed.present?
        accuracy_cards << { value: @profile.accuracy_majority, color: "text-primary", label: "多数派一致率" } if @profile.accuracy_majority.present?
        accuracy_cards << { value: @profile.high_setting_rate, color: "text-slot-red", label: "高設定遭遇率" } if @profile.high_setting_rate.present?
        grid_class = case accuracy_cards.size
                     when 1 then "grid-cols-1"
                     when 2 then "grid-cols-2"
                     else "grid-cols-2 sm:grid-cols-3"
                     end
      %>
      <div class="grid <%= grid_class %> gap-2 mb-4">
        <% accuracy_cards.each do |card| %>
          <div class="bg-surface-inset rounded-lg p-3 text-center <%= 'col-span-2 sm:col-span-1' if accuracy_cards.size == 3 && card == accuracy_cards.last %>">
            <p class="text-xl font-bold <%= card[:color] %> tabular-nums"><%= card[:value] %>%</p>
            <p class="text-[10px] text-muted-foreground mt-0.5"><%= card[:label] %></p>
          </div>
        <% end %>
      </div>
    <% end %>

    <!-- Badges -->
    <div class="mb-4">
      <h2 class="text-sm font-bold text-foreground mb-3 flex items-center gap-2">
        <span class="w-1 h-4 bg-setting-4 rounded-full"></span>
        実績バッジ
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
        <% @badges.each do |badge| %>
          <div class="flex items-center gap-3 bg-card rounded-lg border-b border-border/50 p-3 <%= 'opacity-40' unless badge[:earned] %>">
            <span class="text-2xl"><%= badge[:icon] %></span>
            <div>
              <p class="text-sm font-semibold text-foreground"><%= badge[:name] %></p>
              <p class="text-xs text-muted-foreground"><%= badge[:description] %></p>
            </div>
            <% if badge[:earned] %>
              <span class="ml-auto text-primary">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
              </span>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Recent Votes -->
    <div class="mb-4">
      <h2 class="text-sm font-bold text-foreground mb-3 flex items-center gap-2">
        <span class="w-1 h-4 bg-vote-yes rounded-full"></span>
        最近の記録履歴
      </h2>
      <% if @recent_votes.any? %>
        <div class="bg-card rounded-lg divide-y divide-border/50 border-b border-border/50">
          <% @recent_votes.each do |vote| %>
            <div class="flex items-center gap-3 p-3">
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-foreground truncate">
                  <%= link_to vote.shop.name, shop_path(vote.shop.slug), class: "text-primary hover:underline" %>
                </p>
                <p class="text-xs text-muted-foreground truncate"><%= vote.machine_model.name %></p>
              </div>
              <div class="text-right shrink-0">
                <% if vote.reset_vote.present? %>
                  <span class="inline-block text-[10px] font-medium px-1.5 py-0.5 rounded-md <%= vote.reset_vote == 1 ? 'bg-vote-yes/10 text-vote-yes' : 'bg-secondary text-secondary-foreground' %>">
                    リセ<%= vote.reset_vote == 1 ? "○" : "×" %>
                  </span>
                <% end %>
                <% if vote.setting_vote.present? %>
                  <span class="inline-block text-[10px] font-medium px-1.5 py-0.5 rounded-md bg-primary/10 text-primary">
                    設定<%= vote.setting_vote %>
                  </span>
                <% end %>
                <p class="text-[10px] text-muted-foreground mt-0.5"><%= format_date_with_weekday(vote.voted_on, format: :short) %></p>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-muted-foreground text-center py-4">記録履歴がありません</p>
      <% end %>
    </div>

    <!-- Token Backup (display_name設定済みの場合は畳む) -->
    <% if @profile.display_name.present? %>
      <details class="bg-card rounded-lg border-b border-border/50 mb-4">
        <summary class="p-4 cursor-pointer select-none list-none flex items-center justify-between hover:bg-secondary/50 transition-colors min-h-[44px]">
          <h2 class="text-sm font-bold text-foreground flex items-center gap-2">
            <span class="w-1 h-4 bg-slot-blue rounded-full"></span>
            トークンバックアップ
          </h2>
          <svg class="w-4 h-4 text-muted-foreground transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </summary>
        <div class="px-4 pb-4">
          <p class="text-xs text-muted-foreground mb-2">Cookieが消えるとデータにアクセスできなくなります。</p>
          <div class="flex items-center gap-2" data-controller="clipboard">
            <code class="flex-1 bg-secondary text-foreground text-xs px-3 py-2 rounded font-mono select-all overflow-x-auto" data-clipboard-target="source"><%= cookies[:voter_token] %></code>
            <button type="button" data-clipboard-target="button" data-action="click->clipboard#copy"
                    class="shrink-0 bg-primary text-primary-foreground px-4 py-2.5 rounded text-xs font-medium hover:bg-primary/90 active:scale-95 transition-all min-h-[44px]">
              コピー
            </button>
          </div>
        </div>
      </details>
    <% end %>

  <% else %>
    <!-- No votes yet -->
    <div class="bg-card rounded-lg border-b border-border/50 p-8 text-center">
      <p class="text-4xl mb-3">🎰</p>
      <h2 class="text-base font-semibold text-foreground mb-2">まずは1件、記録してみよう</h2>
      <p class="text-sm text-muted-foreground mb-4">店舗ページでリセ予想や設定読みをポチるだけ。続けると称号が上がっていく。</p>
      <%= link_to "店舗を探す", root_path(anchor: "prefectures"), class: "inline-block bg-primary text-primary-foreground px-6 py-2.5 rounded-lg text-sm font-medium hover:bg-primary/90 active:scale-95 transition-all duration-150 min-h-[44px]" %>
    </div>

    <!-- Token Restore -->
    <div class="bg-card rounded-lg border-b border-border/50 p-4 mt-4">
      <h2 class="text-sm font-bold text-foreground mb-2">トークン復元</h2>
      <p class="text-xs text-muted-foreground mb-3">以前のトークンをお持ちの場合、ここから復元できます。</p>
      <%= form_tag restore_voter_token_path, method: :post, class: "flex items-center gap-2" do %>
        <input type="text" name="token" placeholder="トークンを入力"
               class="flex-1 bg-secondary border border-border text-foreground text-sm px-3 py-2.5 rounded focus:border-primary focus:ring-1 focus:ring-primary/20 focus:outline-none min-h-[44px]"
               required>
        <button type="submit" class="shrink-0 bg-primary text-primary-foreground px-4 py-2.5 rounded text-sm font-medium hover:bg-primary/90 active:scale-95 transition-all min-h-[44px]">
          復元
        </button>
      <% end %>
    </div>
  <% end %>
</section>
