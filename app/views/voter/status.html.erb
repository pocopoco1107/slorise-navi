<% content_for(:title) { "マイステータス | スロリセnavi" } %>

<section class="max-w-2xl mx-auto">
  <h1 class="text-lg font-bold text-foreground mb-4 flex items-center gap-2">
    <span class="w-1 h-5 bg-primary rounded-full"></span>
    マイステータス
  </h1>

  <% if @has_votes %>
    <!-- Voter Identity -->
    <div class="bg-card border border-border rounded-lg p-4 mb-4">
      <p class="text-sm text-muted-foreground">あなたの投票者ID</p>
      <p class="text-xl font-bold text-primary mt-1"><%= @voter_label %></p>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-6">
      <div class="bg-card border border-border rounded-lg p-4 text-center">
        <p class="text-2xl font-bold text-primary tabular-nums"><%= @total_votes_count %></p>
        <p class="text-xs text-muted-foreground mt-1">累計投票</p>
      </div>
      <div class="bg-card border border-border rounded-lg p-4 text-center">
        <p class="text-2xl font-bold text-primary tabular-nums"><%= @shops_count %></p>
        <p class="text-xs text-muted-foreground mt-1">投票店舗</p>
      </div>
      <div class="bg-card border border-border rounded-lg p-4 text-center">
        <p class="text-2xl font-bold text-primary tabular-nums"><%= @machines_count %></p>
        <p class="text-xs text-muted-foreground mt-1">投票機種</p>
      </div>
      <div class="bg-card border border-border rounded-lg p-4 text-center">
        <p class="text-2xl font-bold text-primary tabular-nums"><%= @prefectures_count %></p>
        <p class="text-xs text-muted-foreground mt-1">投票都道府県</p>
      </div>
    </div>

    <!-- Badges -->
    <div class="mb-6">
      <h2 class="text-sm font-bold text-foreground mb-3 flex items-center gap-2">
        <span class="w-1 h-4 bg-setting-4 rounded-full"></span>
        実績バッジ
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
        <% @badges.each do |badge| %>
          <div class="flex items-center gap-3 bg-card border border-border rounded-lg p-3 <%= 'opacity-40' unless badge[:earned] %>">
            <span class="text-2xl"><%= badge[:icon] %></span>
            <div>
              <p class="text-sm font-semibold text-foreground"><%= badge[:name] %></p>
              <p class="text-xs text-muted-foreground"><%= badge[:description] %></p>
            </div>
            <% if badge[:earned] %>
              <span class="ml-auto text-primary">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
              </span>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Recent Votes -->
    <div class="mb-6">
      <h2 class="text-sm font-bold text-foreground mb-3 flex items-center gap-2">
        <span class="w-1 h-4 bg-vote-yes rounded-full"></span>
        最近の投票履歴
      </h2>
      <% if @recent_votes.any? %>
        <div class="bg-card border border-border rounded-lg divide-y divide-border">
          <% @recent_votes.each do |vote| %>
            <div class="flex items-center gap-3 p-3">
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-foreground truncate">
                  <%= link_to vote.shop.name, shop_path(vote.shop.slug), class: "text-primary hover:underline" %>
                </p>
                <p class="text-xs text-muted-foreground truncate"><%= vote.machine_model.name %></p>
              </div>
              <div class="text-right shrink-0">
                <% if vote.reset_vote.present? %>
                  <span class="inline-block text-[10px] font-medium px-1.5 py-0.5 rounded-md <%= vote.reset_vote == 1 ? 'bg-vote-yes/10 text-vote-yes' : 'bg-secondary text-secondary-foreground' %>">
                    リセ<%= vote.reset_vote == 1 ? "○" : "×" %>
                  </span>
                <% end %>
                <% if vote.setting_vote.present? %>
                  <span class="inline-block text-[10px] font-medium px-1.5 py-0.5 rounded-md bg-primary/10 text-primary">
                    設定<%= vote.setting_vote %>
                  </span>
                <% end %>
                <p class="text-[10px] text-muted-foreground mt-0.5"><%= vote.voted_on.strftime("%m/%d") %></p>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-muted-foreground text-center py-4">投票履歴がありません</p>
      <% end %>
    </div>

  <% else %>
    <!-- No votes yet -->
    <div class="bg-card border border-border rounded-lg p-8 text-center">
      <p class="text-4xl mb-3">🎰</p>
      <h2 class="text-base font-semibold text-foreground mb-2">まだ投票していません</h2>
      <p class="text-sm text-muted-foreground mb-4">店舗ページから投票すると、ここにあなたの投票統計とバッジが表示されます。</p>
      <%= link_to "都道府県から店舗を探す", root_path, class: "inline-block bg-primary text-primary-foreground px-6 py-2.5 rounded-lg text-sm font-medium hover:bg-primary/90 active:scale-95 transition-all duration-150 min-h-[44px]" %>
    </div>
  <% end %>
</section>
