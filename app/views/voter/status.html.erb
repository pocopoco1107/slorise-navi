<% content_for(:title) { "マイステータス | スロリセnavi" } %>

<section class="max-w-2xl mx-auto">
  <h1 class="text-lg font-bold text-gray-800 dark:text-gray-100 mb-4 border-l-4 border-blue-700 dark:border-blue-500 pl-2">マイステータス</h1>

  <% if @has_votes %>
    <!-- Voter Identity -->
    <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-4 shadow-sm mb-4">
      <p class="text-sm text-gray-500 dark:text-gray-400">あなたの投票者ID</p>
      <p class="text-xl font-bold text-blue-800 dark:text-blue-400 mt-1"><%= @voter_label %></p>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-6">
      <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-4 shadow-sm text-center">
        <p class="text-2xl font-bold text-blue-800 dark:text-blue-400"><%= @total_votes_count %></p>
        <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">累計投票</p>
      </div>
      <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-4 shadow-sm text-center">
        <p class="text-2xl font-bold text-blue-800 dark:text-blue-400"><%= @shops_count %></p>
        <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">投票店舗</p>
      </div>
      <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-4 shadow-sm text-center">
        <p class="text-2xl font-bold text-blue-800 dark:text-blue-400"><%= @machines_count %></p>
        <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">投票機種</p>
      </div>
      <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-4 shadow-sm text-center">
        <p class="text-2xl font-bold text-blue-800 dark:text-blue-400"><%= @prefectures_count %></p>
        <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">投票都道府県</p>
      </div>
    </div>

    <!-- Badges -->
    <div class="mb-6">
      <h2 class="text-sm font-bold text-gray-800 dark:text-gray-100 mb-3 border-l-4 border-amber-500 pl-2">実績バッジ</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
        <% @badges.each do |badge| %>
          <div class="flex items-center gap-3 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-3 shadow-sm <%= 'opacity-40' unless badge[:earned] %>">
            <span class="text-2xl"><%= badge[:icon] %></span>
            <div>
              <p class="text-sm font-semibold text-gray-800 dark:text-gray-100"><%= badge[:name] %></p>
              <p class="text-xs text-gray-500 dark:text-gray-400"><%= badge[:description] %></p>
            </div>
            <% if badge[:earned] %>
              <span class="ml-auto text-emerald-500">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
              </span>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Recent Votes -->
    <div class="mb-6">
      <h2 class="text-sm font-bold text-gray-800 dark:text-gray-100 mb-3 border-l-4 border-green-500 pl-2">最近の投票履歴</h2>
      <% if @recent_votes.any? %>
        <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl shadow-sm divide-y divide-gray-100 dark:divide-gray-700">
          <% @recent_votes.each do |vote| %>
            <div class="flex items-center gap-3 p-3">
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-gray-800 dark:text-gray-100 truncate">
                  <%= link_to vote.shop.name, shop_path(vote.shop.slug), class: "text-blue-700 dark:text-blue-400 hover:underline" %>
                </p>
                <p class="text-xs text-gray-500 dark:text-gray-400 truncate"><%= vote.machine_model.name %></p>
              </div>
              <div class="text-right shrink-0">
                <% if vote.reset_vote.present? %>
                  <span class="inline-block text-[10px] font-medium px-1.5 py-0.5 rounded-full <%= vote.reset_vote == 1 ? 'bg-green-50 dark:bg-green-900/40 text-green-700 dark:text-green-400' : 'bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300' %>">
                    リセ<%= vote.reset_vote == 1 ? "○" : "×" %>
                  </span>
                <% end %>
                <% if vote.setting_vote.present? %>
                  <span class="inline-block text-[10px] font-medium px-1.5 py-0.5 rounded-full bg-blue-50 dark:bg-blue-900/40 text-blue-700 dark:text-blue-400">
                    設定<%= vote.setting_vote %>
                  </span>
                <% end %>
                <p class="text-[10px] text-gray-400 mt-0.5"><%= vote.voted_on.strftime("%m/%d") %></p>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-gray-500 dark:text-gray-400 text-center py-4">投票履歴がありません</p>
      <% end %>
    </div>

  <% else %>
    <!-- No votes yet -->
    <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-8 shadow-sm text-center">
      <p class="text-4xl mb-3">🎰</p>
      <h2 class="text-base font-semibold text-gray-800 dark:text-gray-100 mb-2">まだ投票していません</h2>
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">店舗ページから投票すると、ここにあなたの投票統計とバッジが表示されます。</p>
      <%= link_to "都道府県から店舗を探す", root_path, class: "inline-block bg-blue-700 dark:bg-blue-600 text-white px-6 py-2.5 rounded-lg text-sm font-medium hover:bg-blue-600 dark:hover:bg-blue-500 active:scale-95 transition-all duration-150 min-h-[44px]" %>
    </div>
  <% end %>
</section>
