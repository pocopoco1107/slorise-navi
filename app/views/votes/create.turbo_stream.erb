<%= turbo_stream.replace "machine_vote_#{@machine_model.id}" do %>
  <%= render "shops/machine_vote_row",
    machine_model: @machine_model,
    vote_summary: @vote_summary,
    user_vote: @vote,
    user_play_record: PlayRecord.find_by(voter_token: cookies[:voter_token], shop_id: @shop.id, machine_model_id: @machine_model.id, played_on: @vote.voted_on),
    shop: @shop,
    date: @vote.voted_on,
    unit_count: ShopMachineModel.find_by(shop_id: @shop.id, machine_model_id: @machine_model.id)&.unit_count %>
<% end %>
